<!-- ══════════════════════════════════════════════
     CONTENIDO PRINCIPAL
══════════════════════════════════════════════ -->
<div class="hist-root">

    <!-- Header -->
    <div class="hist-header">
        <div>
            <h1>Historial de ventas</h1>
            <p>@totalVentas ventas registradas en el sistema</p>
        </div>
    </div>

    <!-- Stat pills -->
    <div class="stat-pills">
        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:#eff6ff;">
                <svg viewBox="0 0 24 24" stroke="#1d4ed8"><rect x="2" y="3" width="20" height="14" rx="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" /></svg>
            </div>
            <div class="stat-pill-info">
                <span>Total ventas</span>
                <strong>@totalVentas</strong>
            </div>
        </div>

        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:#f0fdf4;">
                <svg viewBox="0 0 24 24" stroke="#16a34a"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z" /><path d="M12 6v6l4 2" /></svg>
            </div>
            <div class="stat-pill-info">
                <span>Total hoy</span>
                <strong style="color:#16a34a;">$@totalHoy.ToString("N2")</strong>
            </div>
        </div>

        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:#eff6ff;">
                <svg viewBox="0 0 24 24" stroke="#1d4ed8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            </div>
            <div class="stat-pill-info">
                <span>Total mes</span>
                <strong>$@totalMes.ToString("N2")</strong>
            </div>
        </div>

        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:#fefce8;">
                <svg viewBox="0 0 24 24" stroke="#ca8a04"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
            </div>
            <div class="stat-pill-info">
                <span>Promedio venta</span>
                <strong>$@(totalVentas > 0 ? (ventas.Sum(v => v.Total) / totalVentas).ToString("N2") : "0.00")</strong>
            </div>
        </div>
    </div>

    <!-- Toolbar / Filtros -->
    <div class="hist-toolbar">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input class="hist-input" @bind="busqueda" @bind:event="oninput" placeholder="Buscar por vendedor o ID..." />
        </div>
        <select class="hist-select" @bind="filtroMetodo">
            <option value="">Todos los métodos</option>
            <option value="Efectivo">💵 Efectivo</option>
            <option value="Tarjeta">💳 Tarjeta</option>
            <option value="Transferencia">🏦 Transferencia</option>
        </select>
        <input class="hist-date" @bind="fechaDesde" type="date" title="Desde" />
        <input class="hist-date" @bind="fechaHasta" type="date" title="Hasta" />
        <button class="btn-clear" @onclick="LimpiarFiltros">
            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            Limpiar
        </button>
    </div>

    <!-- Tabla / estados -->
    @if (cargando)
    {
        <div class="table-card">
            <div class="hist-empty">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
                <strong>Cargando historial...</strong>
                <p>Por favor espera un momento</p>
            </div>
        </div>
    }
    else if (!VentasFiltradas.Any())
    {
        <div class="table-card">
            <div class="hist-empty">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                <strong>No se encontraron ventas</strong>
                <p>Intenta con otros filtros o un rango de fechas diferente</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <table class="hist-table">
                <thead>
                    <tr>
                        <th># Venta</th>
                        <th>Fecha</th>
                        <th>Vendedor</th>
                        <th>Método</th>
                        <th class="center">Items</th>
                        <th class="right">Total</th>
                        <th class="center">Estado</th>
                        <th class="right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rowIdx = 0;
                    }
                    @foreach (var v in VentasFiltradas)
                    {
                        var vendedor = v.Usuario != null ? $"{v.Usuario.Nombre} {v.Usuario.Apellido}" : "—";
                        var metodoIcon = v.Pago?.Metodo == "Efectivo" ? "💵" : v.Pago?.Metodo == "Tarjeta" ? "💳" : "🏦";
                        var delay = (rowIdx * 0.04).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
                        rowIdx++;

                        <tr style="animation-delay:@(delay)s;" @onclick="() => VerDetalle(v)">
                            <td><span class="sale-id">#@v.IdVenta</span></td>
                            <td>
                                <div class="sale-date-main">@v.FechaPedido?.ToString("dd/MM/yyyy")</div>
                                <div class="sale-date-time">@v.FechaPedido?.ToString("HH:mm") hrs</div>
                            </td>
                            <td><span class="sale-vendor">@vendedor</span></td>
                            <td>
                                <span class="metodo-badge">@metodoIcon @v.Pago?.Metodo</span>
                            </td>
                            <td class="center">
                                <span style="font-weight:600;color:#475569;">@v.Detalles.Count</span>
                            </td>
                            <td class="right">
                                <span class="sale-total">$@v.Total.ToString("N2")</span>
                            </td>
                            <td class="center">
                                <span class="status-badge">@v.Estado</span>
                            </td>
                            <td>
                                <div class="row-actions">
                                    <button class="btn-row btn-row-ghost" @onclick:stopPropagation @onclick="() => VerDetalle(v)">
                                        <svg viewBox="0 0 24 24" stroke="currentColor"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                        Ver
                                    </button>
                                    <button class="btn-row btn-row-invoice" @onclick:stopPropagation @onclick="() => VerFactura(v)">
                                        <svg viewBox="0 0 24 24" stroke="currentColor"><path d="M6 9V2h12v7" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
                                        Factura
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" style="font-size:12px;">
                            Mostrando <strong style="color:#0d1b4b;">@VentasFiltradas.Count()</strong> ventas
                        </td>
                        <td class="tfoot-total">$@VentasFiltradas.Sum(v => v.Total).ToString("N2")</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@code {
    Venta? ventaFactura;
    ExportacionFactura? facturaHistorial;

    async Task VerFactura(Venta v)
    {
        ventaFactura = v;
        facturaHistorial = await Db.Facturas
            .AsNoTracking()
            .FirstOrDefaultAsync(f => f.IdVenta == v.IdVenta);
    }

    async Task ImprimirFacturaHistorial()
    {
        await JS.InvokeVoidAsync("eval", @"
            var content = document.getElementById('factura-historial-print').innerHTML;
            var win = window.open('', '_blank');
            win.document.write('<html><head><title>Factura</title><style>body{font-family:sans-serif;padding:2rem;}table{width:100%;border-collapse:collapse;}th,td{padding:8px 0;}</style></head><body>' + content + '</body></html>');
            win.document.close();
            win.print();
        ");
    }

    bool cargando = true;
    List<Venta> ventas = new();
    Venta? ventaDetalle;

    string busqueda = "";
    string filtroMetodo = "";
    DateTime? fechaDesde;
    DateTime? fechaHasta;

    int totalVentas;
    decimal totalHoy;
    decimal totalMes;

    IEnumerable<Venta> VentasFiltradas => ventas.Where(v =>
        (string.IsNullOrEmpty(busqueda) ||
         v.IdVenta.ToString().Contains(busqueda) ||
         (v.Usuario != null && $"{v.Usuario.Nombre} {v.Usuario.Apellido}".Contains(busqueda, StringComparison.OrdinalIgnoreCase)))
        && (string.IsNullOrEmpty(filtroMetodo) || v.Pago?.Metodo == filtroMetodo)
        && (fechaDesde == null || v.FechaPedido >= fechaDesde)
        && (fechaHasta == null || v.FechaPedido < fechaHasta.Value.AddDays(1)));

    protected override async Task OnInitializedAsync()
    {
        ventas = await Db.Ventas
            .Include(v => v.Usuario)
            .Include(v => v.Pago)
            .Include(v => v.Detalles)
                .ThenInclude(d => d.Producto)
            .OrderByDescending(v => v.FechaPedido)
            .ToListAsync();

        totalVentas = ventas.Count;
        totalHoy = ventas.Where(v => v.FechaPedido >= DateTime.Today).Sum(v => v.Total);
        totalMes = ventas.Where(v => v.FechaPedido >= new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).Sum(v => v.Total);
        cargando = false;
    }

    void VerDetalle(Venta v) => ventaDetalle = v;

    void LimpiarFiltros()
    {
        busqueda = "";
        filtroMetodo = "";
        fechaDesde = null;
        fechaHasta = null;
    }
}
