<!-- ══════════════════════════════════════════════
     MODAL — DETALLE DE VENTA
══════════════════════════════════════════════ -->
@if (ventaDetalle != null)
{
    <div class="modal-backdrop" @onclick="() => ventaDetalle = null">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-top-bar"></div>

            <div class="modal-header">
                <h2>Venta <span style="color:#1a4bbd;">#@ventaDetalle.IdVenta</span></h2>
                <button class="modal-close" @onclick="() => ventaDetalle = null">✕</button>
            </div>

            <div class="modal-body">
                <div class="info-grid">
                    <div class="info-cell">
                        <div class="info-cell-label">Fecha</div>
                        <div class="info-cell-value">@ventaDetalle.FechaPedido?.ToString("dd/MM/yyyy")</div>
                        <div style="font-size:11px;color:#94a3b8;margin-top:2px;">@ventaDetalle.FechaPedido?.ToString("HH:mm") hrs</div>
                    </div>
                    <div class="info-cell">
                        <div class="info-cell-label">Estado</div>
                        <div class="info-cell-value" style="color:#16a34a;">@ventaDetalle.Estado</div>
                    </div>
                    <div class="info-cell">
                        <div class="info-cell-label">Vendedor</div>
                        <div class="info-cell-value">
                            @(ventaDetalle.Usuario != null ? $"{ventaDetalle.Usuario.Nombre} {ventaDetalle.Usuario.Apellido}" : "—")
                        </div>
                    </div>
                    <div class="info-cell">
                        <div class="info-cell-label">Método de pago</div>
                        <div class="info-cell-value">@(ventaDetalle.Pago?.Metodo ?? "—")</div>
                    </div>
                </div>

                <p class="section-label">Productos</p>
                <table class="prod-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Cant.</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in ventaDetalle.Detalles)
                        {
                            <tr>
                                <td>
                                    <div class="prod-name">@d.Producto?.Nombre</div>
                                    @if (d.Producto?.Talla != null)
                                    {
                                        <div class="prod-size">Talla @d.Producto.Talla</div>
                                    }
                                </td>
                                <td>@d.Cantidad</td>
                                <td>$@d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="total-row">
                    <span class="total-row-label">Total de la venta</span>
                    <span class="total-row-amount">$@ventaDetalle.Total.ToString("N2")</span>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline" @onclick="() => ventaDetalle = null">Cerrar</button>
                    <button class="btn btn-primary" @onclick="() => { VerFactura(ventaDetalle!); ventaDetalle = null; }">
                        <svg viewBox="0 0 24 24" stroke="white"><path d="M6 9V2h12v7" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
                        Ver factura
                    </button>
                </div>
            </div>
        </div>
    </div>
}

