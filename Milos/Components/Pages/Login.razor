@page "/login"
@rendermode InteractiveServer
@layout Milos.Components.Layout.EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Nav
@inject AuthState AuthState

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Syne:wght@700;800&display=swap');

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .login-root {
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        display: flex;
        background: #f0f4ff;
        overflow: hidden;
    }

    /* ── Left panel ── */
    .login-panel-left {
        flex: 1;
        background: linear-gradient(160deg, #0a1f6e 0%, #1a4bbd 55%, #2f7bff 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 60px 70px;
        position: relative;
        overflow: hidden;
    }

        /* Decorative blobs */
        .login-panel-left::before {
            content: '';
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
            top: -100px;
            right: -120px;
            animation: floatBlob 8s ease-in-out infinite;
        }

        .login-panel-left::after {
            content: '';
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            bottom: -60px;
            left: -60px;
            animation: floatBlob 11s ease-in-out infinite reverse;
        }

    @@keyframes floatBlob {
        0%, 100% {
            transform: translateY(0) scale(1);
        }

        50% {
            transform: translateY(-20px) scale(1.04);
        }
    }

    .blob-mid {
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        top: 50%;
        right: 30px;
        transform: translateY(-50%);
        animation: floatBlob 14s ease-in-out infinite;
    }

    .left-grid {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
        background-size: 40px 40px;
    }

    .left-content {
        position: relative;
        z-index: 2;
        animation: slideInLeft 0.8s cubic-bezier(.22,.68,0,1.2) both;
    }

    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 16px; 
        padding: 5px 11px;
        margin-bottom: 40px;
        backdrop-filter: blur(8px);
        margin-left: 220px;
    }   
}

    .brand-badge-dot {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(135deg, #60a5fa, #a78bfa);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .brand-badge-dot svg {
            width: 14px;
            height: 14px;
            fill: white;
        }

    .brand-badge span {
        color: rgba(255,255,255,0.9);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .left-heading {
        font-family: 'Syne', sans-serif;
        font-size: clamp(32px, 4vw, 52px);
        font-weight: 800;
        color: white;
        line-height: 1.1;
        margin-bottom: 20px;
        letter-spacing: -0.02em;
    }

        .left-heading em {
            font-style: normal;
            background: linear-gradient(90deg, #93c5fd, #c4b5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .left-sub {
        color: rgba(255,255,255,0.65);
        font-size: 15px;
        font-weight: 300;
        line-height: 1.7;
        max-width: 340px;
        margin-bottom: 50px;
    }

    .left-features {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 14px;
        animation: fadeUp 0.6s ease both;
    }

        .feature-item:nth-child(1) {
            animation-delay: 0.3s;
        }

        .feature-item:nth-child(2) {
            animation-delay: 0.45s;
        }

        .feature-item:nth-child(3) {
            animation-delay: 0.6s;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .feature-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .feature-icon svg {
            width: 16px;
            height: 16px;
            stroke: rgba(255,255,255,0.9);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .feature-text {
        color: rgba(255,255,255,0.75);
        font-size: 13.5px;
        font-weight: 400;
    }

    /* ── Right panel ── */
    .login-panel-right {
        width: 460px;
        flex-shrink: 0;
        background: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 60px 50px;
        position: relative;
        box-shadow: -20px 0 60px rgba(0,0,0,0.08);
        animation: slideInRight 0.7s cubic-bezier(.22,.68,0,1.2) both;
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .right-top-line {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #1a4bbd, #60a5fa, #a78bfa);
    }

    .form-greeting {
        font-size: 13px;
        font-weight: 500;
        color: #1a4bbd;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .form-title {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #0d1b4b;
        margin-bottom: 6px;
        letter-spacing: -0.02em;
    }

    .form-subtitle {
        color: #94a3b8;
        font-size: 13.5px;
        font-weight: 300;
        margin-bottom: 36px;
    }

    /* Error */
    .login-error {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: #fff1f2;
        border: 1px solid #fecdd3;
        border-left: 3px solid #e11d48;
        border-radius: 8px;
        padding: 12px 14px;
        margin-bottom: 22px;
        font-size: 13.5px;
        color: #be123c;
        animation: shakeError 0.4s ease both;
    }

    @@keyframes shakeError {
        0%, 100% {
            transform: translateX(0);
        }

        20% {
            transform: translateX(-6px);
        }

        40% {
            transform: translateX(6px);
        }

        60% {
            transform: translateX(-4px);
        }

        80% {
            transform: translateX(4px);
        }
    }

    .login-error svg {
        width: 16px;
        height: 16px;
        stroke: #e11d48;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* Fields */
    .field-group {
        margin-bottom: 22px;
        animation: fadeUp 0.5s ease both;
    }

        .field-group:nth-child(1) {
            animation-delay: 0.15s;
        }

        .field-group:nth-child(2) {
            animation-delay: 0.25s;
        }

    .field-label {
        display: block;
        margin-bottom: 8px;
        color: #374151;
        font-weight: 500;
        font-size: 13px;
        letter-spacing: 0.01em;
    }

    .field-wrapper {
        position: relative;
    }

    .field-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        width: 17px;
        height: 17px;
        stroke: #94a3b8;
        fill: none;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
        pointer-events: none;
        transition: stroke 0.25s;
    }

    .field-input {
        width: 100%;
        padding: 13px 15px 13px 42px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: #0d1b4b;
        background: #f8faff;
        transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
        outline: none;
    }

        .field-input::placeholder {
            color: #c1cce0;
        }

        .field-input:focus {
            border-color: #1a4bbd;
            background: white;
            box-shadow: 0 0 0 4px rgba(26,75,189,0.1);
        }

            .field-input:focus + .field-icon,
            .field-wrapper:focus-within .field-icon {
                stroke: #1a4bbd;
            }

    /* This targets the icon when input is focused — note Blazor renders input before the icon sibling */
    .field-wrapper:focus-within .field-icon {
        stroke: #1a4bbd;
    }

    /* Submit button */
    .btn-login {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #0a1f6e 0%, #1a4bbd 60%, #2f7bff 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        margin-top: 10px;
        letter-spacing: 0.01em;
        position: relative;
        overflow: hidden;
        animation: fadeUp 0.5s 0.35s ease both;
    }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
        }

        .btn-login:not(:disabled):hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(26,75,189,0.35);
        }

        .btn-login:not(:disabled):active {
            transform: translateY(0);
            box-shadow: none;
        }

        .btn-login:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    /* Loading spinner inside button */
    .btn-inner {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.35);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Footer note */
    .form-footer {
        margin-top: 30px;
        text-align: center;
        color: #cbd5e1;
        font-size: 12px;
    }

    /* Responsive: stack on small screens */
    @@media (max-width: 768px) {
        .login-root {
            flex-direction: column;
        }

        .login-panel-left {
            padding: 40px 30px;
            flex: none;
        }

        .left-features {
            display: none;
        }

        .login-panel-right {
            width: 100%;
            padding: 40px 28px;
        }
    }
</style>

<div class="login-root">

    <!-- ── LEFT PANEL ── -->
    <div class="login-panel-left">
        <div class="left-grid"></div>
        <div class="blob-mid"></div>

        <div class="left-content">
            <div class="brand-badge">
                <img src="/ChatGPT Image 13 may 2026, 14_40_21.png"
                     alt="Milo's SVI"
                     style="height: 290px; width: auto; object-fit: contain; border-radius: 10px;" />
            </div>

            <h1 class="left-heading">
                <br /><em>Bienvenido</em>
            </h1>
            <p class="left-sub">
                Accede al panel de control
            </p>

            <div class="left-features">
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    </div>
                    <span class="feature-text">Acceso seguro con autenticación protegida</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" /></svg>
                    </div>
                    <span class="feature-text">
                        @horaActual.ToString("dddd, dd MMM yyyy · hh:mm:ss tt")
                    </span>
                </div>
              
            </div>
        </div>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="login-panel-right">
        <div class="right-top-line"></div>

        <p class="form-greeting">Portal de acceso</p>
        <h2 class="form-title">Iniciar sesión</h2>
        <p class="form-subtitle">Ingresa tus credenciales para continuar</p>

        @if (error != null)
        {
            <div class="login-error">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                <span>@error</span>
            </div>
        }

        <div class="field-group">
            <label class="field-label" for="correo">Correo Electrónico</label>
            <div class="field-wrapper">
                <input class="field-input"
                       type="email"
                       id="correo"
                       @bind="correo"
                       placeholder="tu@email.com"
                       required />
                <svg class="field-icon" viewBox="0 0 24 24">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
            </div>
        </div>

        <div class="field-group">
            <label class="field-label" for="password">Contraseña</label>
            <div class="field-wrapper">
                <input class="field-input"
                       type="password"
                       id="password"
                       @bind="password"
                       placeholder="••••••••"
                       required />
                <svg class="field-icon" viewBox="0 0 24 24">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
        </div>

        <button class="btn-login"
                type="button"
                @onclick="IniciarSesion"
                disabled="@isLoading">
            <span class="btn-inner">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Verificando...</span>
                }
                else
                {
                    <span>Entrar al sistema</span>
                }
            </span>
        </button>

        <p class="form-footer">© @DateTime.Now.Year Milo's SVI · Todos los derechos reservados</p>
    </div>
</div>
@implements IDisposable
@code {
    string correo = "";
    string password = "";
    string? error;
    bool isLoading = false;

    DateTime horaActual = DateTime.Now;
    System.Timers.Timer? reloj;

    protected override void OnInitialized()
    {
        if (AuthState.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);

        reloj = new System.Timers.Timer(1000);
        reloj.Elapsed += async (_, _) =>
        {
            horaActual = DateTime.Now;
            await InvokeAsync(StateHasChanged);
        };
        reloj.Start();
    }

    public void Dispose()
    {
        reloj?.Dispose();
    }

    async Task IniciarSesion()
    {
        error = null;
        isLoading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(correo) ||
                string.IsNullOrWhiteSpace(password))
            {
                error = "Correo y contraseña son requeridos";
                return;
            }

            var user = await AuthService.Login(
                correo.Trim(),
                password.Trim());

            if (user == null)
            {
                error = "Credenciales incorrectas";
                return;
            }

            AuthState.Login(user);
            Nav.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}