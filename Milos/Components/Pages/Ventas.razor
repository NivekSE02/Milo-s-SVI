@page "/ventas"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject AuthState AuthState
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore

<PageTitle>Ventas — Milo's SVI</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Syne:wght@@700;800&display=swap');

    .vta-root * {
        box-sizing: border-box;
    }

    /* ── Mismo background ── */
    .vta-root {
        font-family: 'DM Sans', sans-serif;
        background: #f0f4ff;
        min-height: 100vh;
        padding: 32px 36px 60px;
        color: #0d1b4b;
    }

    /* ── Animaciones ── */
    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes backdropIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(14px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ──  header ── */
    .vta-header {
        margin-bottom: 28px;
        animation: fadeDown 0.45s ease both;
    }

        .vta-header h1 {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0 0 4px;
            color: #0d1b4b;
        }

        .vta-header p {
            font-size: 13px;
            color: #7c8db5;
            margin: 0;
        }

    /* ── Error  ── */
    .vta-error {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: #fff1f2;
        border: 1.5px solid #fecdd3;
        border-left: 3px solid #e11d48;
        border-radius: 10px;
        padding: 12px 14px;
        font-size: 13px;
        color: #be123c;
        margin-bottom: 20px;
        animation: fadeUp 0.2s ease both;
    }

        .vta-error svg {
            width: 15px;
            height: 15px;
            fill: none;
            stroke: #e11d48;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            margin-top: 1px;
        }

    /* ──  layout dos columnas ── */
    .vta-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 20px;
        align-items: start;
    }

    .vta-left {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* ──  paneles blancos ── */
    .panel {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 20px 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        animation: fadeUp 0.45s ease both;
    }

    .panel-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* ── Barra busqueda ── */
    .search-wrap {
        position: relative;
    }

        .search-wrap svg {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            width: 15px;
            height: 15px;
            stroke: #94a3b8;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            pointer-events: none;
        }

    .search-input {
        width: 100%;
        padding: 11px 14px 11px 38px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13.5px;
        font-family: 'DM Sans', sans-serif;
        background: #f8faff;
        color: #0d1b4b;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

        .search-input::placeholder {
            color: #b0bcd4;
        }

        .search-input:focus {
            border-color: #1a4bbd;
            background: white;
            box-shadow: 0 0 0 3px rgba(26,75,189,0.1);
        }

    /* ── Resultados ── */
    .results-dropdown {
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        margin-top: 8px;
        background: white;
        box-shadow: 0 8px 28px rgba(26,75,189,0.1);
        animation: slideDown 0.15s ease both;
    }

    .result-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.12s;
        gap: 12px;
    }

        .result-item:last-child {
            border-bottom: none;
        }

        .result-item:hover {
            background: #f0f4ff;
        }

            .result-item:hover .result-add {
                opacity: 1;
                transform: scale(1);
            }

    .result-name {
        font-size: 13.5px;
        font-weight: 600;
        color: #0d1b4b;
    }

    .result-meta {
        font-size: 11.5px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .result-price {
        font-size: 14px;
        font-weight: 700;
        color: #1a4bbd;
        white-space: nowrap;
    }

    .result-add {
        opacity: 0;
        transform: scale(0.85);
        width: 26px;
        height: 26px;
        background: linear-gradient(135deg, #1a4bbd, #2f7bff);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 18px;
        font-weight: 400;
        line-height: 1;
        transition: opacity 0.15s, transform 0.15s;
        flex-shrink: 0;
    }

    .no-results {
        padding: 12px 4px;
        font-size: 13px;
        color: #94a3b8;
    }

    /* ── Cart table ── */
    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

        .cart-table th {
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #94a3b8;
            padding: 0 0 10px;
            border-bottom: 1.5px solid #f1f5f9;
        }

        .cart-table td {
            padding: 12px 0;
            border-bottom: 1px solid #f8fafc;
            font-size: 13px;
            color: #374151;
            vertical-align: middle;
        }

        .cart-table tr:last-child td {
            border-bottom: none;
        }

    .cart-prod-name {
        font-weight: 600;
        color: #0d1b4b;
    }

    .cart-prod-size {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    /* ── Qty controls ── */
    .qty-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .qty-btn {
        width: 28px;
        height: 28px;
        border: 1.5px solid #e2e8f0;
        border-radius: 7px;
        background: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        color: #475569;
        transition: border-color 0.15s, background 0.15s, color 0.15s;
        line-height: 1;
        font-family: 'DM Sans', sans-serif;
    }

        .qty-btn:hover {
            border-color: #1a4bbd;
            background: #eff6ff;
            color: #1a4bbd;
        }

    .qty-val {
        font-weight: 700;
        min-width: 22px;
        text-align: center;
        color: #0d1b4b;
        font-size: 13.5px;
    }

    .remove-btn {
        width: 28px;
        height: 28px;
        border: none;
        background: none;
        cursor: pointer;
        border-radius: 7px;
        color: #c7d7f8;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, color 0.15s;
    }

        .remove-btn:hover {
            background: #fef2f2;
            color: #ef4444;
        }

    /* ──Carrito vacio ── */
    .empty-cart {
        text-align: center;
        padding: 36px 16px;
        color: #c7d7f8;
    }

        .empty-cart svg {
            width: 44px;
            height: 44px;
            margin-bottom: 10px;
            stroke: #c7d7f8;
            fill: none;
            stroke-width: 1.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .empty-cart p {
            font-size: 13px;
            margin: 0;
            color: #94a3b8;
        }

    /* ── Panel derecho ── */
    .vta-right {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        position: sticky;
        top: 24px;
        animation: fadeUp 0.5s 0.1s ease both;
    }

    .right-top-accent {
        height: 3px;
        background: linear-gradient(90deg, #0a1f6e, #1a4bbd, #60a5fa);
        border-radius: 3px;
        margin-bottom: 20px;
    }

    /* ──  display ── */
    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding-bottom: 18px;
        border-bottom: 1.5px solid #f1f5f9;
        margin-bottom: 18px;
    }

    .total-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #94a3b8;
    }

    .total-amount {
        font-family: 'Syne', sans-serif;
        font-size: 30px;
        font-weight: 800;
        color: #0d1b4b;
        letter-spacing: -0.03em;
    }

    /* ── Metodos de pago ── */
    .pay-section-label {
        font-size: 12px;
        color: #64748b;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .pay-methods {
        display: flex;
        gap: 6px;
    }

    .pay-btn {
        flex: 1;
        padding: 10px 6px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: white;
        font-size: 12px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        color: #64748b;
        transition: all 0.15s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
    }

    .pay-btn-icon {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        transition: background 0.15s, color 0.15s;
    }

    .pay-btn.active {
        border-color: #1a4bbd;
        background: #eff6ff;
        color: #1d4ed8;
    }

        .pay-btn.active .pay-btn-icon {
            background: linear-gradient(135deg, #1a4bbd, #2f7bff);
            color: white;
        }

    .pay-btn:not(.active) .pay-btn-icon {
        background: #f1f5f9;
        color: #64748b;
    }

    .pay-btn:not(.active):hover {
        border-color: #c7d7f8;
        background: #f8faff;
    }

    /* ── Efectivo  ── */
    .cash-section {
        margin-top: 14px;
        animation: fadeUp 0.2s ease both;
    }

    .cash-label {
        font-size: 12px;
        color: #64748b;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .cash-input {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 18px;
        font-weight: 700;
        font-family: 'Syne', sans-serif;
        color: #0d1b4b;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: #f8faff;
        letter-spacing: -0.02em;
    }

        .cash-input:focus {
            border-color: #1a4bbd;
            box-shadow: 0 0 0 3px rgba(26,75,189,0.1);
            background: white;
        }

    .cambio-card {
        border-radius: 10px;
        padding: 12px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
        font-size: 13px;
        font-weight: 600;
    }

    .cambio-ok {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    .cambio-err {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecdd3;
    }

    .cambio-card span:last-child {
        font-size: 16px;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    /* ── Cobrar  ── */
    .cobrar-btn {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #0a1f6e 0%, #1a4bbd 60%, #2f7bff 100%);
        color: white;
        font-size: 15px;
        font-weight: 700;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
        letter-spacing: -0.01em;
        margin-top: 18px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(26,75,189,0.3);
    }

        .cobrar-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
        }

        .cobrar-btn:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(26,75,189,0.4);
        }

        .cobrar-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .cobrar-btn:disabled {
            background: #e2e8f0;
            color: #94a3b8;
            cursor: not-allowed;
            box-shadow: none;
        }

    .cobrar-inner {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .cobrar-inner svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: white;
            stroke-width: 2.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* ── Cancelar ── */
    .cancel-btn {
        width: 100%;
        padding: 11px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: white;
        color: #64748b;
        font-size: 13px;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        margin-top: 8px;
    }

        .cancel-btn:hover {
            background: #f8faff;
            border-color: #c7d7f8;
            color: #374151;
        }

    .cart-badge {
        font-size: 11px;
        background: #eff6ff;
        color: #1d4ed8;
        padding: 2px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(10,20,60,0.5);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(4px);
        animation: backdropIn 0.2s ease both;
    }

    /* ── Factura modal ── */
    .factura-modal {
        background: white;
        border-radius: 16px;
        width: 100%;
        max-width: 520px;
        max-height: 92vh;
        overflow-y: auto;
        box-shadow: 0 28px 80px rgba(0,0,0,0.2);
        animation: modalIn 0.3s cubic-bezier(.22,.68,0,1.2) both;
    }

    .factura-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 22px;
        border-bottom: 1.5px solid #e8edf7;
        background: #f8faff;
        border-radius: 16px 16px 0 0;
    }

    .factura-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        font-weight: 600;
        color: #0d1b4b;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: #16a34a;
        border-radius: 50%;
    }

    .factura-actions {
        display: flex;
        gap: 8px;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        border-radius: 9px;
        font-size: 13px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s;
    }

        .btn svg {
            width: 13px;
            height: 13px;
            fill: none;
            stroke-width: 2.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .btn-primary {
        background: linear-gradient(135deg, #0a1f6e 0%, #1a4bbd 60%, #2f7bff 100%);
        color: white;
        border: none;
        box-shadow: 0 3px 12px rgba(26,75,189,0.25);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(26,75,189,0.35);
        }

    .btn-outline {
        background: white;
        color: #374151;
        border: 1.5px solid #e2e8f0;
    }

        .btn-outline:hover {
            background: #f8faff;
            border-color: #c7d7f8;
            transform: translateY(-1px);
        }

    /* ── Factura content ── */
    .factura-body {
        padding: 28px;
    }

    .factura-brand-bar {
        height: 3px;
        background: linear-gradient(90deg, #0a1f6e, #1a4bbd, #60a5fa);
        border-radius: 2px;
        margin-bottom: 22px;
    }

    .factura-logo-wrap {
        text-align: center;
        margin-bottom: 22px;
        padding-bottom: 20px;
        border-bottom: 1.5px solid #e8edf7;
    }

    .factura-logo-icon {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #0a1f6e, #2f7bff);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Syne', sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: white;
        margin: 0 auto 10px;
    }

    .factura-brand-name {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: #0d1b4b;
        letter-spacing: -0.02em;
        margin: 0 0 3px;
    }

    .factura-brand-sub {
        font-size: 12px;
        color: #94a3b8;
        margin: 0;
    }

    .factura-meta {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    .fac-label {
        font-size: 10px;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: 3px;
    }

    .fac-num {
        font-family: 'Syne', sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: #0d1b4b;
        letter-spacing: -0.02em;
    }

    .fac-date {
        font-size: 13px;
        font-weight: 600;
        color: #0d1b4b;
    }

    .fac-time {
        font-size: 11px;
        color: #94a3b8;
    }

    .fac-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 18px;
    }

    .fac-info-cell {
        background: #f8faff;
        border: 1px solid #e8edf7;
        border-radius: 9px;
        padding: 10px 12px;
    }

        .fac-info-cell .fac-label {
            margin-bottom: 3px;
        }

    .fac-info-value {
        font-size: 13px;
        font-weight: 600;
        color: #0d1b4b;
    }

    .fac-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 16px;
    }

        .fac-table thead tr {
            border-bottom: 2px solid #e8edf7;
        }

        .fac-table thead th {
            padding: 7px 0;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

            .fac-table thead th:first-child {
                text-align: left;
            }

            .fac-table thead th:not(:first-child) {
                text-align: right;
            }

        .fac-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
        }

            .fac-table tbody tr:last-child {
                border-bottom: none;
            }

        .fac-table td {
            padding: 9px 0;
            vertical-align: middle;
        }

            .fac-table td:not(:first-child) {
                text-align: right;
                color: #64748b;
            }

            .fac-table td:last-child {
                font-weight: 700;
                color: #0d1b4b;
            }

    .fac-total-box {
        background: #eff6ff;
        border: 1.5px solid #bfdbfe;
        border-radius: 10px;
        padding: 14px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .fac-total-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #1e40af;
    }

