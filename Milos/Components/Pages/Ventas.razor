<!-- ══════════════════════════════════════════════
     CONTENIDO PRINCIPAL
══════════════════════════════════════════════ -->
<div class="vta-root">

    <!-- Header -->
    <div class="vta-header">
        <h1>Nueva venta</h1>
        <p>@DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy")</p>
    </div>

    <!-- Error banner -->
    @if (errorGeneral != null)
    {
        <div class="vta-error">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            @errorGeneral
        </div>
    }

    <div class="vta-layout">

        <!-- ── Left panel ── -->
        <div class="vta-left">

            <!-- Buscador -->
            <div class="panel" style="animation-delay:0.05s;">
                <div class="panel-label">Agregar producto</div>
                <div class="search-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input class="search-input"
                           @bind="busqueda"
                           @bind:event="oninput"
                           @bind:after="BuscarProductos"
                           placeholder="Escribe el nombre del producto..." />
                </div>

                @if (resultadosBusqueda.Any())
                {
                    <div class="results-dropdown">
                        @foreach (var p in resultadosBusqueda)
                        {
                            var agotado = p.Stock == 0;
                            <div class="result-item"
                                 style="opacity:@(agotado ? "0.5" : "1");cursor:@(agotado ? "not-allowed" : "pointer");"
                                 @onclick="() => { if (!agotado) AgregarProducto(p); }">
                                <div style="flex:1;min-width:0;">
                                    <div class="result-name">@p.Nombre @(p.Talla != null ? $"· T.{p.Talla}" : "")</div>
                                    <div class="result-meta">@(p.Categoria?.NombreCategoria ?? "Sin cat.") · @p.Stock unid.</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
                                    <span class="result-price">$@p.PrecioUnitario.ToString("N2")</span>
                                    @if (!agotado)
                                    {
                                        <div class="result-add">+</div>
                                    }
                                    else
                                    {
                                        <span style="font-size:11px;color:#ef4444;background:#fef2f2;padding:2px 8px;border-radius:5px;font-weight:600;">Sin stock</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (busqueda.Length > 1)
                {
                    <div class="no-results">Sin resultados para "<strong>@busqueda</strong>"</div>
                }
            </div>

            <!-- Carrito -->
            <div class="panel" style="animation-delay:0.1s;">
                <div class="panel-label">
                    <span>Carrito</span>
                    @if (carrito.Any())
                    {
                        <span class="cart-badge">@carrito.Count producto@(carrito.Count != 1 ? "s" : "")</span>
                    }
                </div>

                @if (!carrito.Any())
                {
                    <div class="empty-cart">
                        <svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6" /></svg>
                        <p>Agrega productos desde el buscador de arriba</p>
                    </div>
                }
                else
                {
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th style="text-align:left;">Producto</th>
                                <th style="text-align:center;width:110px;">Cantidad</th>
                                <th style="text-align:right;">Precio</th>
                                <th style="text-align:right;">Subtotal</th>
                                <th style="width:32px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in carrito)
                            {
                                <tr>
                                    <td>
                                        <div class="cart-prod-name">@item.Producto.Nombre</div>
                                        @if (item.Producto.Talla != null)
                                        {
                                            <div class="cart-prod-size">Talla @item.Producto.Talla</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="qty-wrap">
                                            <button class="qty-btn" @onclick="() => CambiarCantidad(item, -1)">−</button>
                                            <span class="qty-val">@item.Cantidad</span>
                                            <button class="qty-btn" @onclick="() => CambiarCantidad(item, 1)">+</button>
                                        </div>
                                    </td>
                                    <td style="text-align:right;color:#64748b;">$@item.Producto.PrecioUnitario.ToString("N2")</td>
                                    <td style="text-align:right;font-weight:700;color:#0d1b4b;">$@item.Subtotal.ToString("N2")</td>
                                    <td style="text-align:right;">
                                        <button class="remove-btn" @onclick="() => QuitarProducto(item)">×</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- ── Right panel — Cobro ── -->
        <div class="vta-right">
            <div class="right-top-accent"></div>

            <!-- Total -->
            <div class="total-row">
                <span class="total-label">Total</span>
                <span class="total-amount">$@totalVenta.ToString("N2")</span>
            </div>

            <!-- Métodos de pago -->
            <p class="pay-section-label">Método de pago</p>
            <div class="pay-methods">
                @foreach (var m in new[] {
                                ("Efectivo",       "EF", "#15803d"),
                                ("Tarjeta",        "TC", "#1d4ed8"),
                                ("Transferencia",  "TR", "#7c3aed")
                                })
                {
                    var activo = metodoPago == m.Item1;
                    <button class="pay-btn @(activo ? "active" : "")"
                            @onclick='() => { metodoPago = m.Item1; montoPagado = 0; }'>
                        <span class="pay-btn-icon"
                              style="background:@(activo? m.Item3: "#f1f5f9");color:@(activo ? "white" : "#64748b");">
                            @m.Item2
                        </span>
                        <span>@m.Item1</span>
                    </button>
                }
            </div>

            <!-- Campo efectivo -->
            @if (metodoPago == "Efectivo")
            {
                <div class="cash-section">
                    <p class="cash-label">Monto recibido</p>
                    <input class="cash-input"
                           type="number" step="0.01"
                           @bind="montoPagado"
                           @bind:event="oninput"
                           placeholder="0.00" />

                    @if (montoPagado > 0)
                    {
                        @if (cambio >= 0)
                        {
                            <div class="cambio-card cambio-ok">
                                <span>Cambio</span>
                                <span>$@cambio.ToString("N2")</span>
                            </div>
                        }
                        else
                        {
                            <div class="cambio-card cambio-err">
                                <span>Faltan</span>
                                <span>$@Math.Abs(cambio).ToString("N2")</span>
                            </div>
                        }
                    }
                </div>
            }

            <!-- Cobrar -->
            <button class="cobrar-btn"
                    @onclick="RegistrarVenta"
                    disabled="@(carrito.Count == 0 || procesando || (metodoPago == "Efectivo" && cambio < 0))">
                <span class="cobrar-inner">
                    @if (procesando)
                    {
                        <svg viewBox="0 0 24 24" stroke="white" style="animation:spin .7s linear infinite;">
                            <circle cx="12" cy="12" r="10" stroke-opacity=".25" />
                            <path d="M12 2a10 10 0 0 1 10 10" stroke-opacity="1" />
                        </svg>
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" stroke="white"><path d="M20 12V22H4V12" /><path d="M22 7H2v5h20V7z" /><path d="M12 22V7" /><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" /><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" /></svg>
                        <span>Cobrar $@totalVenta.ToString("N2")</span>
                    }
                </span>
            </button>

            @if (carrito.Any())
            {
                <button class="cancel-btn" @onclick="LimpiarCarrito">Cancelar venta</button>
            }
        </div>
    </div>
</div>

<style>
    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    decimal ultimoCambio;
    decimal ultimoMontoPagado;

    class ItemCarrito
    {
        public Producto Producto { get; set; } = default!;
        public int Cantidad { get; set; }
        public decimal Subtotal => Producto.PrecioUnitario * Cantidad;
    }

    record ItemFactura(string Nombre, string? Talla, int Cantidad, decimal PrecioUnitario, decimal Subtotal);

    List<ItemCarrito> carrito = new();
    List<Producto> resultadosBusqueda = new();
    List<ItemFactura> itemsFactura = new();
    ExportacionFactura? facturaActual;

    string busqueda = "";
    string metodoPago = "Efectivo";
    decimal montoPagado = 0;
    bool procesando = false;
    bool mostrarExito = false;
    decimal ultimoTotal = 0;
    string? errorGeneral;

    decimal totalVenta => carrito.Sum(i => i.Subtotal);
    decimal cambio => montoPagado - totalVenta;

    async Task BuscarProductos()
    {
        if (busqueda.Length < 2) { resultadosBusqueda.Clear(); return; }
        resultadosBusqueda = await Db.Productos
            .Include(p => p.Categoria)
            .Where(p => p.Nombre.Contains(busqueda))
            .Take(6)
            .ToListAsync();
    }

    void AgregarProducto(Producto p)
    {
        var item = carrito.FirstOrDefault(i => i.Producto.IdProducto == p.IdProducto);
        if (item != null) { if (item.Cantidad < p.Stock) item.Cantidad++; }
        else carrito.Add(new ItemCarrito { Producto = p, Cantidad = 1 });
        busqueda = "";
        resultadosBusqueda.Clear();
    }

    void CambiarCantidad(ItemCarrito item, int delta)
    {
        int nueva = item.Cantidad + delta;
        if (nueva <= 0) carrito.Remove(item);
        else if (nueva <= item.Producto.Stock) item.Cantidad = nueva;
    }

    void QuitarProducto(ItemCarrito item) => carrito.Remove(item);

    void LimpiarCarrito()
    {
        carrito.Clear();
        busqueda = "";
        resultadosBusqueda.Clear();
        montoPagado = 0;
        errorGeneral = null;
    }

    async Task RegistrarVenta()
    {
        if (procesando) return;
        procesando = true;
        errorGeneral = null;

        try
        {
            var pago = new Pago { Metodo = metodoPago, Monto = totalVenta, Fecha_Pago = DateTime.Now };
            Db.Pagos.Add(pago);
            await Db.SaveChangesAsync();

            var venta = new Venta
            {
                IdUsuario = AuthState.IdUsuario,
                IdPago = pago.IdPago,
                FechaPedido = DateTime.Now,
                Total = totalVenta,
                Estado = "Completada"
            };
            Db.Ventas.Add(venta);
            await Db.SaveChangesAsync();

            foreach (var item in carrito)
            {
                Db.DetallesVenta.Add(new DetalleVenta
                {
                    IdVenta = venta.IdVenta,
                    IdProducto = item.Producto.IdProducto,
                    Cantidad = item.Cantidad,
                    Subtotal = item.Subtotal
                });
                var p = await Db.Productos.FindAsync(item.Producto.IdProducto);
                if (p != null) p.Stock -= item.Cantidad;
            }

            var factura = new ExportacionFactura { Estado = 1, Fecha = DateTime.Now, IdVenta = venta.IdVenta };
            Db.Facturas.Add(factura);
            await Db.SaveChangesAsync();

            itemsFactura = carrito.Select(c => new ItemFactura(c.Producto.Nombre, c.Producto.Talla, c.Cantidad, c.Producto.PrecioUnitario, c.Subtotal)).ToList();
            ultimoTotal = totalVenta;
            ultimoCambio = cambio > 0 ? cambio : 0;
            ultimoMontoPagado = montoPagado;

            await Task.Delay(200);
            facturaActual = await Db.Facturas.AsNoTracking()
                .FirstOrDefaultAsync(f => f.IdExportacion == factura.IdExportacion);

            carrito.Clear();
            mostrarExito = true;
        }
        catch (Exception ex)
        {
            errorGeneral = "Error al registrar la venta: " + ex.Message;
        }
        finally
        {
            procesando = false;
        }
    }

    async Task ImprimirFactura()
    {
        var filas = new System.Text.StringBuilder();
        foreach (var i in itemsFactura)
        {
            filas.Append("<tr>");
            filas.Append("<td>");
            filas.Append($"<div class=\"prod-name\">{i.Nombre}</div>");
            if (i.Talla != null)
                filas.Append($"<div class=\"prod-talla\">Talla {i.Talla}</div>");
            filas.Append("</td>");
            filas.Append($"<td>{i.Cantidad}</td>");
            filas.Append($"<td>${i.PrecioUnitario:N2}</td>");
            filas.Append($"<td>${i.Subtotal:N2}</td>");
            filas.Append("</tr>");
        }

        var cambioHtml = "";
        if (metodoPago == "Efectivo" && ultimoMontoPagado > 0)
        {
            cambioHtml = $@"<div class=""cambio-row""><span>Recibido</span><span>${ultimoMontoPagado:N2}</span></div>
                        <div class=""cambio-row green""><span>Cambio</span><span>${ultimoCambio:N2}</span></div>";
        }

        var vendedor = string.IsNullOrEmpty(AuthState.Nombre) ? "—" : AuthState.Nombre;
        var numFactura = facturaActual?.NumeroFactura ?? "";
        var fecha = facturaActual?.Fecha?.ToString("dd/MM/yyyy") ?? "";
        var hora = facturaActual?.Fecha?.ToString("HH:mm") ?? "";
        var fechaCompleta = facturaActual?.Fecha?.ToString("dd/MM/yyyy HH:mm") ?? "";

        var html = @"<!DOCTYPE html>
<html>
<head>
<meta charset='utf-8'>
<title>Factura " + numFactura + @"</title>
<link href='https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Syne:wght@700;800&display=swap' rel='stylesheet'>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: DM Sans, sans-serif; color: #0d1b4b; padding: 32px; background: white; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
.brand-bar { height: 4px; background: linear-gradient(90deg, #0a1f6e, #1a4bbd, #60a5fa); border-radius: 2px; margin-bottom: 24px; }
.logo-wrap { text-align: center; margin-bottom: 22px; padding-bottom: 20px; border-bottom: 1.5px solid #e8edf7; }
.logo-icon { width: 44px; height: 44px; background: linear-gradient(135deg, #0a1f6e, #2f7bff); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-family: Syne, sans-serif; font-size: 20px; font-weight: 800; color: white; margin: 0 auto 10px; }
.brand-name { font-family: Syne, sans-serif; font-size: 22px; font-weight: 800; color: #0d1b4b; letter-spacing: -0.02em; margin: 0 0 3px; }
.brand-sub { font-size: 12px; color: #94a3b8; margin: 0; }
.meta { display: flex; justify-content: space-between; margin-bottom: 18px; }
.fac-label { font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: .07em; margin-bottom: 3px; }
.fac-num { font-family: Syne, sans-serif; font-size: 20px; font-weight: 800; color: #0d1b4b; }
.fac-date { font-size: 13px; font-weight: 600; color: #0d1b4b; }
.fac-time { font-size: 11px; color: #94a3b8; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
.info-cell { background: #f8faff; border: 1px solid #e8edf7; border-radius: 9px; padding: 10px 12px; }
.info-value { font-size: 13px; font-weight: 600; color: #0d1b4b; }
table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 16px; }
thead tr { border-bottom: 2px solid #e8edf7; }
thead th { padding: 7px 0; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .06em; }
thead th:first-child { text-align: left; }
thead th:not(:first-child) { text-align: right; }
tbody tr { border-bottom: 1px solid #f1f5f9; }
td { padding: 9px 0; vertical-align: middle; }
td:not(:first-child) { text-align: right; color: #64748b; }
td:last-child { font-weight: 700; color: #0d1b4b; }
.prod-name { font-weight: 600; color: #0d1b4b; }
.prod-talla { font-size: 11px; color: #94a3b8; }
.cambio-row { display: flex; justify-content: space-between; font-size: 13px; color: #64748b; margin-bottom: 4px; }
.cambio-row.green { color: #16a34a; font-weight: 600; }
.total-box { background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 10px; padding: 14px 16px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.total-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #1e40af; }
.total-amount { font-family: Syne, sans-serif; font-size: 22px; font-weight: 800; color: #1a4bbd; }
.footer { text-align: center; padding-top: 16px; border-top: 1px dashed #e2e8f0; margin-top: 14px; }
.footer p { font-size: 12px; color: #94a3b8; margin: 0 0 3px; }
.footer small { font-size: 10px; color: #c7d7f8; }
</style>
</head>
<body>
  <div class='brand-bar'></div>
  <div class='logo-wrap'>
    <div class='logo-icon'>M</div>
    <p class='brand-name'>Milo's SVI</p>
    <p class='brand-sub'>Santa Ana, El Salvador</p>
  </div>
  <div class='meta'>
    <div>
      <div class='fac-label'>Numero de factura</div>
      <div class='fac-num'>" + numFactura + @"</div>
    </div>
    <div style='text-align:right;'>
      <div class='fac-label'>Fecha y hora</div>
      <div class='fac-date'>" + fecha + @"</div>
      <div class='fac-time'>" + hora + @" hrs</div>
    </div>
  </div>
  <div class='info-grid'>
    <div class='info-cell'>
      <div class='fac-label'>Vendedor</div>
      <div class='info-value'>" + vendedor + @"</div>
    </div>
    <div class='info-cell'>
      <div class='fac-label'>Metodo de pago</div>
      <div class='info-value'>" + metodoPago + @"</div>
    </div>
  </div>
  <table>
    <thead><tr><th>Producto</th><th>Cant.</th><th>P. Unit.</th><th>Total</th></tr></thead>
    <tbody>" + filas.ToString() + @"</tbody>
  </table>
  " + cambioHtml + @"
  <div class='total-box'>
    <span class='total-label'>Total pagado</span>
    <span class='total-amount'>$" + ultimoTotal.ToString("N2") + @"</span>
  </div>
  <div class='footer'>
    <p>Gracias por su compra en Milo's SVI!</p>
    <small>" + numFactura + " · " + fechaCompleta + @"</small>
  </div>
</body>
</html>";

        await JS.InvokeVoidAsync("imprimirFactura", html);
    }

    void NuevaVenta()
    {
        mostrarExito = false;
        facturaActual = null;
        montoPagado = 0;
        ultimoCambio = 0;
    }
}
