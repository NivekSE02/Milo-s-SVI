@page "/ventas"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject AuthState AuthState
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore

<PageTitle>Ventas — Milo's SVI</PageTitle>

<style>
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.02);
        }
    }

    .ventas-page {
        animation: fadeUp 0.4s ease both;
    }

    .search-input {
        width: 100%;
        padding: 11px 16px 11px 42px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        background: white;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        box-sizing: border-box;
        color: #1e293b;
    }

        .search-input:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
        }

        .search-input::placeholder {
            color: #94a3b8;
        }

    .search-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .results-dropdown {
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        margin-top: 6px;
        background: white;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        animation: fadeUp 0.15s ease both;
    }

    .result-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 11px 16px;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.12s;
    }

        .result-item:last-child {
            border-bottom: none;
        }

        .result-item:hover {
            background: #f0f7ff;
        }

            .result-item:hover .result-add {
                opacity: 1;
            }

    .result-add {
        opacity: 0;
        width: 24px;
        height: 24px;
        background: #2563eb;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 16px;
        transition: opacity 0.15s;
        flex-shrink: 0;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

        .cart-table th {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #94a3b8;
            padding: 0 0 10px;
            border-bottom: 1.5px solid #f1f5f9;
        }

        .cart-table td {
            padding: 12px 0;
            border-bottom: 1px solid #f8fafc;
            font-size: 13px;
            color: #334155;
            vertical-align: middle;
        }

        .cart-table tr:last-child td {
            border-bottom: none;
        }

    .qty-btn {
        width: 26px;
        height: 26px;
        border: 1.5px solid #e2e8f0;
        border-radius: 6px;
        background: white;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        color: #475569;
        transition: border-color 0.15s, background 0.15s;
        line-height: 1;
    }

        .qty-btn:hover {
            border-color: #2563eb;
            background: #eff6ff;
            color: #2563eb;
        }

    .remove-btn {
        width: 26px;
        height: 26px;
        border: none;
        background: none;
        cursor: pointer;
        border-radius: 6px;
        color: #cbd5e1;
        font-size: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, color 0.15s;
    }

        .remove-btn:hover {
            background: #fef2f2;
            color: #ef4444;
        }

    .metodo-btn {
        flex: 1;
        padding: 10px 8px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: white;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        color: #64748b;
        transition: all 0.15s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

        .metodo-btn.active {
            border-color: #2563eb;
            background: #eff6ff;
            color: #1d4ed8;
        }

        .metodo-btn:not(.active):hover {
            border-color: #bfdbfe;
            background: #f8fafc;
        }

        .metodo-btn svg {
            width: 18px;
            height: 18px;
        }

    .cobrar-btn {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 10px;
        background: #2563eb;
        color: white;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
        letter-spacing: -0.2px;
    }

        .cobrar-btn:hover:not(:disabled) {
            background: #1d4ed8;
            box-shadow: 0 4px 16px rgba(37,99,235,0.25);
            transform: translateY(-1px);
        }

        .cobrar-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .cobrar-btn:disabled {
            background: #e2e8f0;
            color: #94a3b8;
            cursor: not-allowed;
        }

    .cancelar-btn {
        width: 100%;
        padding: 11px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: white;
        color: #64748b;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        margin-top: 8px;
    }

        .cancelar-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    .cambio-card {
        border-radius: 10px;
        padding: 12px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
        font-size: 13px;
    }

    .cambio-ok {
        background: #f0fdf4;
        color: #15803d;
    }

    .cambio-err {
        background: #fef2f2;
        color: #dc2626;
    }

    .empty-cart {
        text-align: center;
        padding: 2.5rem 1rem;
        color: #cbd5e1;
    }

        .empty-cart svg {
            width: 40px;
            height: 40px;
            margin-bottom: 8px;
        }

    @@media print {
        body * {
            visibility: hidden !important;
        }

        #factura-print, #factura-print * {
            visibility: visible !important;
        }

        #factura-print {
            position: fixed !important;
            left: 0;
            top: 0;
            width: 100%;
            padding: 2rem;
            background: white;
        }

        .no-print {
            display: none !important;
        }
    }
</style>

@* MODAL FACTURA *@
@if (mostrarExito)
{
    <div style="position:fixed;inset:0;background:rgba(15,23,42,0.5);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;animation:fadeIn 0.2s ease;">
        @if (facturaActual == null)
        {
            <div style="background:white;border-radius:16px;padding:2rem;text-align:center;max-width:380px;width:100%;animation:fadeUp 0.3s ease;">
                <div style="width:52px;height:52px;background:#f0fdf4;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px;">✅</div>
                <p style="font-size:15px;font-weight:500;color:#1e293b;margin:0 0 1.5rem;">Venta registrada</p>
                <button @onclick="NuevaVenta" style="width:100%;padding:12px;border:none;border-radius:10px;background:#2563eb;color:white;font-size:14px;font-weight:600;cursor:pointer;">Nueva venta</button>
            </div>
        }
        else
        {
            <div style="background:white;border-radius:16px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,0.18);animation:fadeUp 0.3s ease;">

                <div class="no-print" style="display:flex;gap:8px;padding:1rem 1.5rem;border-bottom:1px solid #f1f5f9;justify-content:space-between;align-items:center;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div style="width:8px;height:8px;background:#22c55e;border-radius:50%;"></div>
                        <span style="font-size:14px;font-weight:500;color:#1e293b;">Factura generada</span>
                    </div>
                    <div style="display:flex;gap:6px;">
                        <button @onclick="ImprimirFactura"
                                style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:none;border-radius:8px;background:#2563eb;color:white;font-size:13px;font-weight:500;cursor:pointer;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9" /><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
                            Imprimir / PDF
                        </button>
                        <button @onclick="NuevaVenta"
                                style="padding:8px 14px;border:1.5px solid #e2e8f0;border-radius:8px;background:white;font-size:13px;color:#475569;cursor:pointer;">
                            Nueva venta
                        </button>
                    </div>
                </div>

                <div id="factura-print" style="padding:2rem;">
                    <div style="text-align:center;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:2px solid #2563eb;">
                        <div style="width:40px;height:40px;background:#2563eb;border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:18px;font-weight:800;color:white;">M</div>
                        <h1 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 3px;letter-spacing:-0.5px;">Milo's SVI</h1>
                        <p style="font-size:12px;color:#94a3b8;margin:0;">Santa Ana, El Salvador</p>
                    </div>

                    <div style="display:flex;justify-content:space-between;margin-bottom:1.25rem;">
                        <div>
                            <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;">Factura</div>
                            <div style="font-size:20px;font-weight:700;color:#0f172a;">@facturaActual.NumeroFactura</div>
                        </div>
                        <div style="text-align:right;">
                            <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;">Fecha</div>
                            <div style="font-size:13px;font-weight:500;color:#1e293b;">@facturaActual.Fecha?.ToString("dd/MM/yyyy")</div>
                            <div style="font-size:12px;color:#94a3b8;">@facturaActual.Fecha?.ToString("HH:mm") hrs</div>
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1.25rem;">
                        <div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">
                            <div style="font-size:10px;color:#94a3b8;margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em;">Vendedor</div>
                            <div style="font-size:13px;font-weight:500;color:#1e293b;">@(string.IsNullOrEmpty(AuthState.Nombre) ? "—" : AuthState.Nombre)</div>
                        </div>
                        <div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">
                            <div style="font-size:10px;color:#94a3b8;margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em;">Pago</div>
                            <div style="font-size:13px;font-weight:500;color:#1e293b;">@metodoPago</div>
                        </div>
                    </div>

                    <table style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:1.25rem;">
                        <thead>
                            <tr style="border-bottom:1.5px solid #e2e8f0;">
                                <th style="text-align:left;padding:6px 0;font-size:10px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Producto</th>
                                <th style="text-align:center;padding:6px 0;font-size:10px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.06em;width:40px;">Cant.</th>
                                <th style="text-align:right;padding:6px 0;font-size:10px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.06em;width:70px;">P.Unit.</th>
                                <th style="text-align:right;padding:6px 0;font-size:10px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.06em;width:70px;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itemsFactura)
                            {
                                <tr style="border-bottom:1px solid #f8fafc;">
                                    <td style="padding:9px 0;">
                                        <div style="font-weight:500;color:#1e293b;">@item.Nombre</div>
                                        @if (item.Talla != null)
                                        {
                                            <div style="font-size:11px;color:#94a3b8;">Talla @item.Talla</div>
                                        }
                                    </td>
                                    <td style="padding:9px 0;text-align:center;color:#64748b;">@item.Cantidad</td>
                                    <td style="padding:9px 0;text-align:right;color:#64748b;">$@item.PrecioUnitario.ToString("N2")</td>
                                    <td style="padding:9px 0;text-align:right;font-weight:600;color:#1e293b;">$@item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div style="border-top:1.5px solid #e2e8f0;padding-top:1rem;">
                        @if (metodoPago == "Efectivo" && ultimoMontoPagado > 0)
                        {
                            <div style="display:flex;justify-content:space-between;font-size:13px;color:#64748b;margin-bottom:6px;">
                                <span>Recibido</span><span>$@ultimoMontoPagado.ToString("N2")</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;font-size:13px;color:#15803d;margin-bottom:10px;">
                                <span>Cambio</span><span>$@ultimoCambio.ToString("N2")</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;align-items:center;background:#eff6ff;border-radius:8px;padding:12px 14px;">
                            <span style="font-size:13px;font-weight:600;color:#1e40af;">Total pagado</span>
                            <span style="font-size:20px;font-weight:700;color:#1d4ed8;">$@ultimoTotal.ToString("N2")</span>
                        </div>
                    </div>

                    <div style="text-align:center;margin-top:1.5rem;padding-top:1rem;border-top:1px dashed #e2e8f0;">
                        <p style="font-size:12px;color:#94a3b8;margin:0 0 3px;">Gracias por su compra</p>
                        <p style="font-size:10px;color:#cbd5e1;margin:0;">@facturaActual.NumeroFactura · @facturaActual.Fecha?.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* INTERFAZ PRINCIPAL *@
<div class="ventas-page" style="padding:1.5rem 0;">

    <div style="margin-bottom:1.5rem;">
        <h1 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 2px;letter-spacing:-0.4px;">Nueva venta</h1>
        <p style="font-size:13px;color:#94a3b8;margin:0;">@DateTime.Now.ToString("dddd, dd 'de' MMMM yyyy")</p>
    </div>

    @if (errorGeneral != null)
    {
        <div style="background:#fef2f2;border:1.5px solid #fecaca;color:#dc2626;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:1rem;animation:fadeUp 0.2s ease;">
            @errorGeneral
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start;">

        @* Panel izquierdo *@
        <div style="display:flex;flex-direction:column;gap:14px;">

            @* Buscador *@
            <div style="background:white;border:1.5px solid #e2e8f0;border-radius:14px;padding:1.25rem;">
                <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;margin-bottom:12px;">Agregar producto</div>
                <div class="search-wrapper">
                    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input class="search-input" @bind="busqueda" @bind:event="oninput" @bind:after="BuscarProductos" placeholder="Escribe el nombre del producto..." />
                </div>

                @if (resultadosBusqueda.Any())
                {
                    <div class="results-dropdown">
                        @foreach (var p in resultadosBusqueda)
                        {
                            var agotado = p.Stock == 0;
                            <div class="result-item" style="opacity:@(agotado ? "0.5" : "1");cursor:@(agotado ? "not-allowed" : "pointer");"
                                 @onclick="() => { if (!agotado) AgregarProducto(p); }">
                                <div>
                                    <div style="font-size:14px;font-weight:500;color:#1e293b;">@p.Nombre @(p.Talla != null ? $"· T. {p.Talla}" : "")</div>
                                    <div style="font-size:12px;color:#94a3b8;">@p.Categoria?.NombreCategoria · @p.Stock unid. disponibles</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span style="font-size:14px;font-weight:600;color:#2563eb;">$@p.PrecioUnitario.ToString("N2")</span>
                                    @if (!agotado)
                                    {
                                        <div class="result-add">+</div>
                                    }
                                    else
                                    {

                                        <span style="font-size:11px;color:#ef4444;background:#fef2f2;padding:2px 8px;border-radius:4px;">Sin stock</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (busqueda.Length > 1)
                {
                    <div style="padding:10px 4px;font-size:13px;color:#94a3b8;">Sin resultados para "@busqueda"</div>
                }
            </div>

            @* Carrito *@
            <div style="background:white;border:1.5px solid #e2e8f0;border-radius:14px;padding:1.25rem;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;">Carrito</div>
                    @if (carrito.Any())
                    {
                        <span style="font-size:12px;background:#eff6ff;color:#1d4ed8;padding:2px 10px;border-radius:20px;font-weight:500;">@carrito.Count producto@(carrito.Count != 1 ? "s" : "")</span>
                    }
                </div>

                @if (!carrito.Any())
                {
                    <div class="empty-cart">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6" /></svg>
                        <p style="font-size:13px;margin:0;">Agrega productos desde el buscador</p>
                    </div>
                }
                else
                {
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th style="text-align:left;">Producto</th>
                                <th style="text-align:center;width:100px;">Cantidad</th>
                                <th style="text-align:right;">Precio</th>
                                <th style="text-align:right;">Subtotal</th>
                                <th style="width:32px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in carrito)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight:500;color:#1e293b;">@item.Producto.Nombre</div>
                                        @if (item.Producto.Talla != null)
                                        {
                                            <div style="font-size:11px;color:#94a3b8;">Talla @item.Producto.Talla</div>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
                                            <button class="qty-btn" @onclick="() => CambiarCantidad(item, -1)">−</button>
                                            <span style="font-weight:600;min-width:20px;text-align:center;">@item.Cantidad</span>
                                            <button class="qty-btn" @onclick="() => CambiarCantidad(item, 1)">+</button>
                                        </div>
                                    </td>
                                    <td style="text-align:right;color:#64748b;">$@item.Producto.PrecioUnitario.ToString("N2")</td>
                                    <td style="text-align:right;font-weight:600;color:#1e293b;">$@item.Subtotal.ToString("N2")</td>
                                    <td style="text-align:right;">
                                        <button class="remove-btn" @onclick="() => QuitarProducto(item)">×</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* Panel derecho — Cobro *@
        <div style="background:white;border:1.5px solid #e2e8f0;border-radius:14px;padding:1.25rem;position:sticky;top:1rem;">

            <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;margin-bottom:16px;">Resumen</div>

            @* Total *@
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px;padding-bottom:16px;border-bottom:1.5px solid #f1f5f9;">
                <span style="font-size:13px;color:#64748b;">Total</span>
                <span style="font-size:26px;font-weight:700;color:#0f172a;letter-spacing:-1px;">$@totalVenta.ToString("N2")</span>
            </div>

            @* Métodos de pago *@
            <div style="margin-bottom:16px;">
                <div style="font-size:12px;color:#64748b;margin-bottom:8px;">Método de pago</div>
                <div style="display:flex;gap:6px;">
                    @foreach (var m in new[] { ("Efectivo", "M", "#15803d"), ("Tarjeta", "T", "#1d4ed8"), ("Transferencia", "Tr", "#7c3aed") })
                    {
                        var activo = metodoPago == m.Item1;
                        <button class="metodo-btn @(activo ? "active" : "")" @onclick='() => { metodoPago = m.Item1; montoPagado = 0; }'>
                            <span style="font-size:11px;font-weight:700;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:@(activo? m.Item3: "#f1f5f9");color:@(activo ? "white" : "#64748b");">@m.Item2</span>
                            <span style="font-size:11px;">@m.Item1</span>
                        </button>
                    }
                </div>
            </div>

            @* Efectivo *@
            @if (metodoPago == "Efectivo")
            {
                <div style="margin-bottom:14px;animation:fadeUp 0.2s ease;">
                    <div style="font-size:12px;color:#64748b;margin-bottom:6px;">Monto recibido</div>
                    <input type="number" step="0.01" @bind="montoPagado" @bind:event="oninput"
                           style="width:100%;padding:11px 14px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:16px;font-weight:600;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.15s;"
                           onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#e2e8f0'" />

                    @if (montoPagado > 0)
                    {
                        @if (cambio >= 0)
                        {
                            <div class="cambio-card cambio-ok">
                                <span style="font-weight:500;">Cambio</span>
                                <span style="font-size:16px;font-weight:700;">$@cambio.ToString("N2")</span>
                            </div>
                        }
                        else
                        {
                            <div class="cambio-card cambio-err">
                                <span>Faltan</span>
                                <span style="font-weight:700;">$@Math.Abs(cambio).ToString("N2")</span>
                            </div>
                        }
                    }
                </div>
            }

            @* Botón cobrar *@
            <button class="cobrar-btn" @onclick="RegistrarVenta"
                    disabled="@(carrito.Count == 0 || procesando || (metodoPago == "Efectivo" && cambio < 0))">
                @if (procesando)
                {
                    <span>Procesando...</span>
                }
                else
                {
                    <span>Cobrar $@totalVenta.ToString("N2")</span>
                }
            </button>

            @if (carrito.Any())
            {
                <button class="cancelar-btn" @onclick="LimpiarCarrito">Cancelar venta</button>
            }
        </div>
    </div>
</div>

@code {
    decimal ultimoCambio;
    decimal ultimoMontoPagado;

    class ItemCarrito
    {
        public Producto Producto { get; set; } = default!;
        public int Cantidad { get; set; }
        public decimal Subtotal => Producto.PrecioUnitario * Cantidad;
    }
    record ItemFactura(string Nombre, string? Talla, int Cantidad, decimal PrecioUnitario, decimal Subtotal);

    List<ItemCarrito> carrito = new();
    List<Producto> resultadosBusqueda = new();
    List<ItemFactura> itemsFactura = new();
    ExportacionFactura? facturaActual;

    string busqueda = "";
    string metodoPago = "Efectivo";
    decimal montoPagado = 0;
    bool procesando = false;
    bool mostrarExito = false;
    decimal ultimoTotal = 0;
    string? errorGeneral;

    decimal totalVenta => carrito.Sum(i => i.Subtotal);
    decimal cambio => montoPagado - totalVenta;

    async Task BuscarProductos()
    {
        if (busqueda.Length < 2) { resultadosBusqueda.Clear(); return; }
        resultadosBusqueda = await Db.Productos
            .Include(p => p.Categoria)
            .Where(p => p.Nombre.Contains(busqueda))
            .Take(6)
            .ToListAsync();
    }

    void AgregarProducto(Producto p)
    {
        var item = carrito.FirstOrDefault(i => i.Producto.IdProducto == p.IdProducto);
        if (item != null) { if (item.Cantidad < p.Stock) item.Cantidad++; }
        else { carrito.Add(new ItemCarrito { Producto = p, Cantidad = 1 }); }
        busqueda = "";
        resultadosBusqueda.Clear();
    }

    void CambiarCantidad(ItemCarrito item, int delta)
    {
        int nueva = item.Cantidad + delta;
        if (nueva <= 0) carrito.Remove(item);
        else if (nueva <= item.Producto.Stock) item.Cantidad = nueva;
    }

    void QuitarProducto(ItemCarrito item) => carrito.Remove(item);

    void LimpiarCarrito()
    {
        carrito.Clear();
        busqueda = "";
        resultadosBusqueda.Clear();
        montoPagado = 0;
        errorGeneral = null;
    }

    async Task RegistrarVenta()
    {
        if (procesando) return;
        procesando = true;
        errorGeneral = null;

        try
        {
            var pago = new Pago { Metodo = metodoPago, Monto = totalVenta, Fecha_Pago = DateTime.Now };
            Db.Pagos.Add(pago);
            await Db.SaveChangesAsync();

            var venta = new Venta
            {
                IdUsuario = AuthState.IdUsuario,

                IdPago = pago.IdPago,
                FechaPedido = DateTime.Now,
                Total = totalVenta,
                Estado = "Completada"
            };
            Db.Ventas.Add(venta);
            await Db.SaveChangesAsync();

            foreach (var item in carrito)
            {
                Db.DetallesVenta.Add(new DetalleVenta
                {
                    IdVenta = venta.IdVenta,
                    IdProducto = item.Producto.IdProducto,
                    Cantidad = item.Cantidad,
                    Subtotal = item.Subtotal
                });
                var p = await Db.Productos.FindAsync(item.Producto.IdProducto);
                if (p != null) p.Stock -= item.Cantidad;
            }

            var factura = new ExportacionFactura { Estado = 1, Fecha = DateTime.Now, IdVenta = venta.IdVenta };
            Db.Facturas.Add(factura);
            await Db.SaveChangesAsync();

            itemsFactura = carrito.Select(c => new ItemFactura(
                c.Producto.Nombre, c.Producto.Talla, c.Cantidad,
                c.Producto.PrecioUnitario, c.Subtotal)).ToList();
            ultimoTotal = totalVenta;
            ultimoCambio = cambio > 0 ? cambio : 0;
            ultimoMontoPagado = montoPagado;

            await Task.Delay(200);
            facturaActual = await Db.Facturas.AsNoTracking()
                .FirstOrDefaultAsync(f => f.IdExportacion == factura.IdExportacion);

            carrito.Clear();
            mostrarExito = true;
        }
        catch (Exception ex)
        {
            errorGeneral = "Error: " + ex.Message;
        }
        finally
        {
            procesando = false;
        }
    }

    async Task ImprimirFactura() => await JS.InvokeVoidAsync("window.print");

    void NuevaVenta()
    {
        mostrarExito = false;
        facturaActual = null;
        montoPagado = 0;
        ultimoCambio = 0;
    }
}