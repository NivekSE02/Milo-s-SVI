@page "/ventas"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject AuthState AuthState
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore

<PageTitle>Ventas — Milo's SVI</PageTitle>

@* --- MODAL DE FACTURA Y ÉXITO --- *@
@if (mostrarExito)
{
    @if (facturaActual == null)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center;">
            <div style="background:white;border-radius:12px;padding:2rem;text-align:center;">
                <p>✅ Venta registrada pero factura es null</p>
                <button @onclick="NuevaVenta">Nueva venta</button>
            </div>
        </div>
    }
    else
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;">
            <div style="background:white;border-radius:12px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 25px 60px rgba(0,0,0,0.3);">

                <!-- Barra de acciones (no se imprime) -->
                <div class="no-print" style="display:flex;gap:8px;padding:1rem 1.5rem;border-bottom:1px solid #f0f0f0;justify-content:space-between;align-items:center;">
                    <span style="font-size:14px;font-weight:500;color:#333;">✅ Factura generada</span>
                    <div style="display:flex;gap:8px;">
                        <button @onclick="ImprimirFactura"
                                style="padding:8px 16px;border:none;border-radius:6px;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:13px;cursor:pointer;font-weight:500;">
                            🖨️ Imprimir / PDF
                        </button>
                        <button @onclick="NuevaVenta"
                                style="padding:8px 16px;border:1px solid #e0e0e0;border-radius:6px;background:white;font-size:13px;cursor:pointer;">
                            Nueva venta
                        </button>
                    </div>
                </div>

                <!-- Factura imprimible -->
                <div id="factura-print" style="padding:2rem;">

                    <!-- Header -->
                    <div style="text-align:center;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:2px solid #667eea;">
                        <h1 style="font-size:26px;font-weight:700;color:#667eea;margin:0 0 4px;letter-spacing:-0.5px;">Milo's SVI</h1>
                        <p style="font-size:12px;color:#888;margin:0;">Sistema de Ventas e Inventario</p>
                        <p style="font-size:12px;color:#888;margin:2px 0 0;">Santa Ana, El Salvador</p>
                    </div>

                    <!-- Número y fecha -->
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;">
                        <div>
                            <div style="font-size:11px;color:#aaa;text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;">Número de factura</div>
                            <div style="font-size:22px;font-weight:700;color:#333;">@facturaActual.NumeroFactura</div>
                        </div>
                        <div style="text-align:right;">
                            <div style="font-size:11px;color:#aaa;text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;">Fecha y hora</div>
                            <div style="font-size:13px;font-weight:500;color:#333;">@facturaActual.Fecha?.ToString("dd/MM/yyyy")</div>
                            <div style="font-size:12px;color:#888;">@facturaActual.Fecha?.ToString("HH:mm") hrs</div>
                        </div>
                    </div>

                    <!-- Info vendedor y pago -->
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.5rem;">
                        <div style="background:#f9f9f9;border-radius:8px;padding:10px 14px;">
                            <div style="font-size:11px;color:#aaa;margin-bottom:3px;">Atendido por</div>
                            <div style="font-size:13px;font-weight:500;">
                                @(AuthState.CurrentUser != null
                                                        ? $"{AuthState.CurrentUser.Nombre} {AuthState.CurrentUser.Apellido}"
                                                        : "—")
                    </div>
                </div>
                <div style="background:#f9f9f9;border-radius:8px;padding:10px 14px;">
                    <div style="font-size:11px;color:#aaa;margin-bottom:3px;">Método de pago</div>
                    <div style="font-size:13px;font-weight:500;">
                        @(metodoPago == "Efectivo" ? "💵" : metodoPago == "Tarjeta" ? "💳" : "🏦") @metodoPago
                    </div>
                </div>
            </div>

                    <!-- Detalle de productos -->
                    <div style="margin-bottom:1.5rem;">
                        <div style="font-size:11px;font-weight:600;color:#aaa;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Detalle de compra</div>
                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                            <thead>
                                <tr style="border-bottom:2px solid #e5e5e5;">
                                    <th style="text-align:left;padding:8px 0;color:#888;font-weight:500;">Producto</th>
                                    <th style="text-align:center;padding:8px 0;color:#888;font-weight:500;width:50px;">Cant.</th>
                                    <th style="text-align:right;padding:8px 0;color:#888;font-weight:500;width:80px;">P. Unit.</th>
                                    <th style="text-align:right;padding:8px 0;color:#888;font-weight:500;width:80px;">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                        @foreach (var item in itemsFactura)
                                {
                                    <tr style="border-bottom:1px solid #f5f5f5;">
                                        <td style="padding:9px 0;">
                                            <div style="font-weight:500;color:#333;">@item.Nombre</div>
                                            @if (item.Talla != null)
                                            {
                                                <div style="font-size:11px;color:#aaa;">Talla: @item.Talla</div>
                                            }
                                        </td>
                                        <td style="padding:9px 0;text-align:center;color:#555;">@item.Cantidad</td>
                                        <td style="padding:9px 0;text-align:right;color:#555;">$@item.PrecioUnitario.ToString("N2")</td>
                                        <td style="padding:9px 0;text-align:right;font-weight:500;color:#333;">$@item.Subtotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Totales -->
                    <div style="border-top:2px solid #e5e5e5;padding-top:1rem;">
                        @if (metodoPago == "Efectivo" && ultimoMontoPagado > 0)
                        {
                            <div style="display:flex;justify-content:space-between;font-size:13px;color:#888;margin-bottom:6px;">
                                <span>Monto recibido</span>
                                <span>$@ultimoMontoPagado.ToString("N2")</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;font-size:13px;color:#16a34a;margin-bottom:10px;">
                                <span>Cambio</span>
                                <span>$@ultimoCambio.ToString("N2")</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;align-items:center;background:#f0f4ff;border-radius:8px;padding:12px 16px;">
                            <span style="font-size:14px;font-weight:600;color:#333;">TOTAL PAGADO</span>
                            <span style="font-size:20px;font-weight:700;color:#667eea;">$@ultimoTotal.ToString("N2")</span>
                        </div>
                    </div>

                    <!-- Pie de factura -->
                    <div style="text-align:center;margin-top:2rem;padding-top:1rem;border-top:1px dashed #e0e0e0;">
                        <p style="font-size:12px;color:#888;margin:0 0 4px;">¡Gracias por su compra en Milo's SVI!</p>
                        <p style="font-size:10px;color:#ccc;margin:0;">@facturaActual.NumeroFactura · @facturaActual.Fecha?.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                </div>
            </div>
        </div>
    }
}

@* --- INTERFAZ DE VENTA --- *@
<div style="padding:1.5rem 0;">
    <div style="margin-bottom:1.5rem;">
        <h1 style="font-size:18px;font-weight:500;margin:0;">Nueva venta</h1>
        <p style="font-size:13px;color:#888;">@DateTime.Now.ToString("dddd, dd 'de' MMMM yyyy")</p>
    </div>

    @if (errorGeneral != null)
    {
        <div style="color:#dc2626;background:#fef2f2;border:1px solid #fecaca;padding:12px;border-radius:8px;margin-bottom:1rem;">@errorGeneral</div>
    }

    <div style="display:grid;grid-template-columns:1fr 360px;gap:20px;">

        @* Buscador y Carrito *@
        <div>
            <div style="background:white;border:1px solid #e5e5e5;border-radius:12px;padding:1.25rem;margin-bottom:1rem;">
                <input @bind="busqueda" @bind:event="oninput" @bind:after="BuscarProductos"
                       placeholder="Buscar producto..." style="width:100%;padding:10px;border-radius:8px;border:1px solid #e0e0e0;" />

                @if (resultadosBusqueda.Any())
                {
                    <div style="margin-top:8px;border:1px solid #e0e0e0;border-radius:8px;">
                        @foreach (var p in resultadosBusqueda)
                        {
                            <div @onclick="() => AgregarProducto(p)" style="padding:10px;border-bottom:1px solid #f0f0f0;cursor:pointer;">
                                <strong>@p.Nombre</strong> - $@p.PrecioUnitario (Stock: @p.Stock)
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="background:white;border:1px solid #e5e5e5;border-radius:12px;padding:1.25rem;">
                <table style="width:100%;font-size:13px;">
                    <thead>
                        <tr style="color:#888;">
                            <th style="text-align:left;">Producto</th>
                            <th style="text-align:center;">Cantidad</th>
                            <th style="text-align:right;">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in carrito)
                        {
                            <tr>
                                <td>@item.Producto.Nombre</td>
                                <td style="text-align:center;">
                                    <button @onclick="() => CambiarCantidad(item, -1)">-</button>
                                    @item.Cantidad
                                    <button @onclick="() => CambiarCantidad(item, 1)">+</button>
                                </td>
                                <td style="text-align:right;">$@item.Subtotal.ToString("N2")</td>
                                <td><button @onclick="() => QuitarProducto(item)">×</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Resumen de Pago *@
        <div style="background:white;border:1px solid #e5e5e5;border-radius:12px;padding:1.25rem;height:fit-content;">
            <h3>Total: $@totalVenta.ToString("N2")</h3>

            <div style="margin:1rem 0;">
                <label>Método de Pago</label>
                <select @bind="metodoPago" style="width:100%;padding:8px;margin-top:5px;">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Transferencia">Transferencia</option>
                </select>
            </div>

            @if (metodoPago == "Efectivo")
            {
                <input type="number" @bind="montoPagado" @bind:event="oninput" placeholder="Monto recibido" style="width:100%;padding:8px;" />
                <p>Cambio: $@cambio.ToString("N2")</p>
            }

            <button @onclick="RegistrarVenta" disabled="@(carrito.Count == 0 || (metodoPago == "Efectivo" && cambio < 0))"
                    style="width:100%;padding:12px;background:linear-gradient(135deg,#667eea,#764ba2);color:white;border:none;border-radius:8px;font-weight:bold;">
                @(procesando ? "Procesando..." : "REGISTRAR VENTA")
            </button>
        </div>
    </div>
</div>

@code {


    decimal ultimoCambio;
    decimal ultimoMontoPagado;
    // --- Modelos ---
    class ItemCarrito
    {
        public Producto Producto { get; set; } = default!;
        public int Cantidad { get; set; }
        public decimal Subtotal => Producto.PrecioUnitario * Cantidad;
    }
    record ItemFactura(string Nombre, string? Talla, int Cantidad, decimal PrecioUnitario, decimal Subtotal);

    // --- Estado ---
    List<ItemCarrito> carrito = new();
    List<Producto> resultadosBusqueda = new();
    List<ItemFactura> itemsFactura = new();
    ExportacionFactura? facturaActual;

    string busqueda = "";
    string metodoPago = "Efectivo";
    decimal montoPagado = 0;
    bool procesando = false;
    bool mostrarExito = false;
    decimal ultimoTotal = 0;
    string? errorGeneral;

    decimal totalVenta => carrito.Sum(i => i.Subtotal);
    decimal cambio => montoPagado - totalVenta;

    // --- Métodos ---
    async Task BuscarProductos()
    {
        if (busqueda.Length < 2) { resultadosBusqueda.Clear(); return; }
        resultadosBusqueda = await Db.Productos.Where(p => p.Nombre.Contains(busqueda) && p.Stock > 0).Take(5).ToListAsync();
    }

    void AgregarProducto(Producto p)
    {
        var item = carrito.FirstOrDefault(i => i.Producto.IdProducto == p.IdProducto);
        if (item != null) { if (item.Cantidad < p.Stock) item.Cantidad++; }
        else { carrito.Add(new ItemCarrito { Producto = p, Cantidad = 1 }); }
        busqueda = ""; resultadosBusqueda.Clear();
    }

    void CambiarCantidad(ItemCarrito item, int delta)
    {
        int nueva = item.Cantidad + delta;
        if (nueva <= 0) carrito.Remove(item);
        else if (nueva <= item.Producto.Stock) item.Cantidad = nueva;
    }

    void QuitarProducto(ItemCarrito item) => carrito.Remove(item);

    async Task RegistrarVenta()
    {
        if (procesando) return;
        procesando = true;
        errorGeneral = null;

        try
        {
            // 1. Pago
            var pago = new Pago { Metodo = metodoPago, Monto = totalVenta, Fecha_Pago = DateTime.Now };
            Db.Pagos.Add(pago);
            await Db.SaveChangesAsync();

            // 2. Venta
            var venta = new Venta
            {
                IdUsuario = AuthState.CurrentUser!.IdUsuario,
                IdPago = pago.IdPago,
                FechaPedido = DateTime.Now,
                Total = totalVenta,
                Estado = "Completada"
            };
            Db.Ventas.Add(venta);
            await Db.SaveChangesAsync();

            // 3. Detalles y Actualización de Stock (Manual si el trigger no es confiable)
            foreach (var item in carrito)
            {
                Db.DetallesVenta.Add(new DetalleVenta
                {
                    IdVenta = venta.IdVenta,
                    IdProducto = item.Producto.IdProducto,
                    Cantidad = item.Cantidad,
                    Subtotal = item.Subtotal
                });

                var p = await Db.Productos.FindAsync(item.Producto.IdProducto);
                if (p != null) p.Stock -= item.Cantidad;
            }

            // 4. Factura
            var factura = new ExportacionFactura { Estado = 1, Fecha = DateTime.Now, IdVenta = venta.IdVenta };
            Db.Facturas.Add(factura);
            await Db.SaveChangesAsync();

            // Preparar datos para el modal antes de limpiar el carrito
            itemsFactura = carrito.Select(c => new ItemFactura(
       c.Producto.Nombre,
       c.Producto.Talla,
       c.Cantidad,
       c.Producto.PrecioUnitario,
       c.Subtotal
   )).ToList();

            ultimoTotal = totalVenta;

            // Recargar factura para obtener el número generado por la DB
            await Task.Delay(200);
            facturaActual = await Db.Facturas.AsNoTracking().FirstOrDefaultAsync(f => f.IdExportacion == factura.IdExportacion);
            ultimoCambio = cambio > 0 ? cambio : 0;
            ultimoMontoPagado = montoPagado;

            carrito.Clear();
            mostrarExito = true;
        }
        catch (Exception ex)
        {
            errorGeneral = "Error: " + ex.Message;
        }
        finally
        {
            procesando = false;
        }
    }

    async Task ImprimirFactura() => await JS.InvokeVoidAsync("window.print");

    void NuevaVenta()
    {
        mostrarExito = false;
        facturaActual = null;
        montoPagado = 0;
    }
}