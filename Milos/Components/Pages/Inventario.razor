@page "/inventario"
@rendermode InteractiveServer
@inject AppDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Inventario — Milo's SVI</PageTitle>

<!-- Modal Agregar/Editar -->
@if (mostrarModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;display:flex;align-items:center;justify-content:center;" @onclick="CerrarModal">
        <div style="background:white;border-radius:12px;padding:2rem;width:100%;max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,0.2);" @onclick:stopPropagation>
            <h2 style="font-size:16px;font-weight:500;margin:0 0 1.5rem;">@(editando ? "Editar producto" : "Nuevo producto")</h2>

            @if (modalError != null)
            {
                <div style="color:#dc2626;background:#fef2f2;border:1px solid #fecaca;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:1rem;">@modalError</div>
            }

            <div style="display:grid;gap:1rem;">
                <div>
                    <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Nombre</label>
                    <input @bind="form.Nombre" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" />
                </div>
                <div>
                    <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Descripción</label>
                    <input @bind="form.Descripcion" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Precio unitario</label>
                        <input @bind="form.PrecioUnitario" type="number" step="0.01" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" />
                    </div>
                    <div>
                        <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Precio mayoreo</label>
                        <input @bind="form.PrecioMayoreo" type="number" step="0.01" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" />
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Stock</label>
                        <input @bind="form.Stock" type="number" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" />
                    </div>
                    <div>
                        <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Talla</label>
                        <input @bind="form.Talla" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" placeholder="S, M, L, XL..." />
                    </div>
                </div>
                <div>
                    <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">Categoría</label>
                    <select @bind="form.IdCategoria" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;">
                        <option value="0">— Seleccionar —</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.IdCategoria">@cat.NombreCategoria</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="font-size:12px;color:#888;display:block;margin-bottom:4px;">URL de imagen (opcional)</label>
                    <input @bind="form.ImagenURL" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:6px;font-size:14px;" placeholder="https://..." />
                </div>
            </div>

            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1.5rem;">
                <button @onclick="CerrarModal" style="padding:10px 20px;border:1px solid #e0e0e0;border-radius:6px;background:white;font-size:14px;cursor:pointer;">Cancelar</button>
                <button @onclick="GuardarProducto" style="padding:10px 20px;border:none;border-radius:6px;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:14px;cursor:pointer;font-weight:500;">
                    @(guardando ? "Guardando..." : (editando ? "Guardar cambios" : "Agregar producto"))
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (mostrarConfirmarEliminar)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;display:flex;align-items:center;justify-content:center;" @onclick="() => mostrarConfirmarEliminar = false">
        <div style="background:white;border-radius:12px;padding:2rem;width:100%;max-width:380px;" @onclick:stopPropagation>
            <h2 style="font-size:16px;font-weight:500;margin:0 0 0.5rem;">¿Eliminar producto?</h2>
            <p style="font-size:13px;color:#888;margin:0 0 1.5rem;">Esta acción no se puede deshacer. Se eliminará <strong>@productoAEliminar?.Nombre</strong>.</p>
            <div style="display:flex;gap:8px;justify-content:flex-end;">
                <button @onclick="() => mostrarConfirmarEliminar = false" style="padding:10px 20px;border:1px solid #e0e0e0;border-radius:6px;background:white;font-size:14px;cursor:pointer;">Cancelar</button>
                <button @onclick="ConfirmarEliminar" style="padding:10px 20px;border:none;border-radius:6px;background:#dc2626;color:white;font-size:14px;cursor:pointer;font-weight:500;">Eliminar</button>
            </div>
        </div>
    </div>
}

<div style="padding:1.5rem 0;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
        <div>
            <h1 style="font-size:18px;font-weight:500;margin:0;">Inventario</h1>
            <p style="font-size:13px;color:#888;margin:2px 0 0;">@productos.Count productos registrados</p>
        </div>
        <button @onclick="AbrirModalNuevo" style="padding:10px 18px;border:none;border-radius:8px;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:14px;font-weight:500;cursor:pointer;">
            + Nuevo producto
        </button>
    </div>

    <!-- Filtros -->
    <div style="display:flex;gap:10px;margin-bottom:1.5rem;flex-wrap:wrap;">
        <input @bind="busqueda" @bind:event="oninput" placeholder="Buscar producto..."
               style="flex:1;min-width:180px;padding:10px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;" />
        <select @bind="filtroCategoria" style="padding:10px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;background:white;">
            <option value="0">Todas las categorías</option>
            @foreach (var cat in categorias)
            {
                <option value="@cat.IdCategoria">@cat.NombreCategoria</option>
            }
        </select>
        <select @bind="filtroStock" style="padding:10px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;background:white;">
            <option value="todos">Todo el stock</option>
            <option value="critico">Stock crítico (≤10)</option>
            <option value="sinstock">Sin stock</option>
        </select>
    </div>

    <!-- Cards -->
    @if (cargando)
    {
        <div style="text-align:center;padding:3rem;color:#888;font-size:14px;">Cargando inventario...</div>
    }
    else if (!ProductosFiltrados.Any())
    {
        <div style="text-align:center;padding:3rem;color:#aaa;font-size:14px;">No se encontraron productos.</div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;">
            @foreach (var p in ProductosFiltrados)
            {
                var stockColor = p.Stock == 0 ? "#dc2626" : p.Stock <= 10 ? "#f59e0b" : "#16a34a";
                var stockBg = p.Stock == 0 ? "#fef2f2" : p.Stock <= 10 ? "#fffbeb" : "#f0fdf4";
                var stockLabel = p.Stock == 0 ? "Sin stock" : p.Stock <= 10 ? "Stock bajo" : "En stock";

                <div style="background:white;border:1px solid #e5e5e5;border-radius:12px;overflow:hidden;display:flex;flex-direction:column;">
                    <!-- Imagen -->
                    <div style="height:140px;background:#f5f5f3;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                        @if (!string.IsNullOrEmpty(p.ImagenURL))
                        {
                            <img src="@p.ImagenURL" alt="@p.Nombre" style="width:100%;height:100%;object-fit:cover;" />
                        }
                        else
                        {
                            <span style="font-size:40px;">👕</span>
                        }
                    </div>

                    <!-- Info -->
                    <div style="padding:1rem;flex:1;display:flex;flex-direction:column;gap:6px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                            <span style="font-size:14px;font-weight:500;line-height:1.3;">@p.Nombre</span>
                            <span style="font-size:11px;padding:2px 8px;border-radius:20px;background:@stockBg;color:@stockColor;white-space:nowrap;flex-shrink:0;">@stockLabel</span>
                        </div>

                        @if (!string.IsNullOrEmpty(p.Descripcion))
                        {
                            <p style="font-size:12px;color:#888;margin:0;line-height:1.4;">@p.Descripcion</p>
                        }

                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:2px;">
                            @if (!string.IsNullOrEmpty(p.Talla))
                            {
                                <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:#f0f0f0;color:#666;">Talla: @p.Talla</span>
                            }
                            <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:#ede9fe;color:#5b21b6;">@(p.Categoria?.NombreCategoria ?? "Sin categoría")</span>
                        </div>

                        <div style="margin-top:auto;padding-top:10px;border-top:1px solid #f0f0f0;">
                            <div style="display:flex;align-items:center;justify-content:space-between;">
                                <div>
                                    <div style="font-size:15px;font-weight:500;">$@p.PrecioUnitario.ToString("N2")</div>
                                    @if (p.PrecioMayoreo.HasValue)
                                    {
                                        <div style="font-size:11px;color:#888;">Mayoreo: $@p.PrecioMayoreo.Value.ToString("N2")</div>
                                    }
                                </div>
                                <div style="font-size:13px;color:@stockColor;font-weight:500;">@p.Stock unid.</div>
                            </div>
                        </div>

                        <!-- Acciones -->
                        <div style="display:flex;gap:6px;margin-top:8px;">
                            <button @onclick="() => AbrirModalEditar(p)"
                                    style="flex:1;padding:8px;border:1px solid #e0e0e0;border-radius:6px;background:white;font-size:12px;cursor:pointer;color:#333;">
                                ✏️ Editar
                            </button>
                            <button @onclick="() => SolicitarEliminar(p)"
                                    style="flex:1;padding:8px;border:1px solid #fecaca;border-radius:6px;background:white;font-size:12px;cursor:pointer;color:#dc2626;">
                                🗑️ Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    bool cargando = true;
    bool mostrarModal = false;
    bool mostrarConfirmarEliminar = false;
    bool editando = false;
    bool guardando = false;
    string? modalError;

    string busqueda = "";
    int filtroCategoria = 0;
    string filtroStock = "todos";

    List<Producto> productos = new();
    List<CategoriaProducto> categorias = new();
    Producto? productoAEliminar;

    class FormProducto
    {
        public int IdProducto { get; set; }
        public string Nombre { get; set; } = "";
        public string? Descripcion { get; set; }
        public decimal PrecioUnitario { get; set; }
        public decimal? PrecioMayoreo { get; set; }
        public int Stock { get; set; }
        public string? Talla { get; set; }
        public string? ImagenURL { get; set; }
        public int IdCategoria { get; set; }
    }

    FormProducto form = new();

    IEnumerable<Producto> ProductosFiltrados => productos
        .Where(p =>
            (string.IsNullOrEmpty(busqueda) ||
             p.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
             (p.Descripcion?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false))
         && (filtroCategoria == 0 || p.IdCategoria == filtroCategoria)
         && (filtroStock == "todos" ||
             (filtroStock == "critico" && p.Stock <= 10 && p.Stock > 0) ||
             (filtroStock == "sinstock" && p.Stock == 0)));

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    async Task CargarDatos()
    {
        cargando = true;
        categorias = await Db.Categorias.ToListAsync();
        productos = await Db.Productos
            .Include(p => p.Categoria)
            .OrderBy(p => p.Nombre)
            .ToListAsync();
        cargando = false;
    }

    void AbrirModalNuevo()
    {
        editando = false;
        modalError = null;
        form = new FormProducto();
        mostrarModal = true;
    }

    void AbrirModalEditar(Producto p)
    {
        editando = true;
        modalError = null;
        form = new FormProducto
        {
            IdProducto = p.IdProducto,
            Nombre = p.Nombre,
            Descripcion = p.Descripcion,
            PrecioUnitario = p.PrecioUnitario,
            PrecioMayoreo = p.PrecioMayoreo,
            Stock = p.Stock,
            Talla = p.Talla,
            ImagenURL = p.ImagenURL,
            IdCategoria = p.IdCategoria
        };
        mostrarModal = true;
    }

    void CerrarModal()
    {
        mostrarModal = false;
        modalError = null;
    }

    async Task GuardarProducto()
    {
        modalError = null;

        if (string.IsNullOrWhiteSpace(form.Nombre)) { modalError = "El nombre es requerido."; return; }
        if (form.PrecioUnitario <= 0) { modalError = "El precio debe ser mayor a 0."; return; }
        if (form.IdCategoria == 0) { modalError = "Selecciona una categoría."; return; }
        if (form.Stock < 0) { modalError = "El stock no puede ser negativo."; return; }

        guardando = true;

        try
        {
            if (editando)
            {
                var p = await Db.Productos.FindAsync(form.IdProducto);
                if (p != null)
                {
                    p.Nombre = form.Nombre.Trim();
                    p.Descripcion = form.Descripcion?.Trim();
                    p.PrecioUnitario = form.PrecioUnitario;
                    p.PrecioMayoreo = form.PrecioMayoreo;
                    p.Stock = form.Stock;
                    p.Talla = form.Talla?.Trim();
                    p.ImagenURL = form.ImagenURL?.Trim();
                    p.IdCategoria = form.IdCategoria;
                    await Db.SaveChangesAsync();
                }
            }
            else
            {
                var nuevo = new Producto
                {
                    Nombre = form.Nombre.Trim(),
                    Descripcion = form.Descripcion?.Trim(),
                    PrecioUnitario = form.PrecioUnitario,
                    PrecioMayoreo = form.PrecioMayoreo,
                    Stock = form.Stock,
                    Talla = form.Talla?.Trim(),
                    ImagenURL = form.ImagenURL?.Trim(),
                    IdCategoria = form.IdCategoria
                };
                Db.Productos.Add(nuevo);
                await Db.SaveChangesAsync();
            }

            mostrarModal = false;
            await CargarDatos();
        }
        catch (Exception ex)
        {
            modalError = "Error al guardar: " + ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    void SolicitarEliminar(Producto p)
    {
        productoAEliminar = p;
        mostrarConfirmarEliminar = true;
    }

    async Task ConfirmarEliminar()
    {
        if (productoAEliminar == null) return;
        try
        {
            Db.Productos.Remove(productoAEliminar);
            await Db.SaveChangesAsync();
            mostrarConfirmarEliminar = false;
            productoAEliminar = null;
            await CargarDatos();
        }
        catch (Exception ex)
        {
            mostrarConfirmarEliminar = false;
            // Si tiene ventas asociadas, SQL lanzará error de FK
            modalError = "No se puede eliminar: el producto tiene ventas registradas.";
            mostrarModal = false;
        }
    }
}