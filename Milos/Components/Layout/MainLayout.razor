@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar @(navMenu?.collapsed == true ? "collapsed" : "")">
        <NavMenu @ref="navMenu" OnToggle="StateHasChanged" />
    </div>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    NavMenu? navMenu;
}