@inject AuthState AuthState
@inject NavigationManager Nav

<style>
    .topbar {
        background: #0f172a;
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 28px;
        gap: 8px;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .topbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        margin-right: 20px;
        flex-shrink: 0;
    }

    .topbar-brand-icon {
        width: 32px;
        height: 32px;
        background: #2563eb;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 800;
        color: white;
    }

    .topbar-brand-text {
        font-size: 15px;
        font-weight: 700;
        color: white;
        letter-spacing: -0.3px;
        white-space: nowrap;
    }

    /* Nav pills */
    .topbar-nav {
        display: flex;
        align-items: center;
        gap: 2px;
        flex: 1;
    }

    .nav-pill {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 7px 14px;
        border-radius: 8px;
        text-decoration: none;
        color: rgba(255,255,255,0.5);
        font-size: 13.5px;
        font-weight: 500;
        white-space: nowrap;
        border: none;
        background: none;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }

        .nav-pill svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        .nav-pill:hover {
            background: rgba(255,255,255,0.07);
            color: rgba(255,255,255,0.85);
        }

        .nav-pill.active {
            background: rgba(37,99,235,0.25);
            color: #60a5fa;
            border: 1px solid rgba(37,99,235,0.3);
        }

    .nav-divider-v {
        width: 1px;
        height: 20px;
        background: rgba(255,255,255,0.1);
        margin: 0 6px;
        flex-shrink: 0;
    }

    /* Section label inside nav */
    .nav-section-chip {
        font-size: 10px;
        font-weight: 600;
        color: rgba(255,255,255,0.2);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0 6px;
        flex-shrink: 0;
    }

    /* Right side */
    .topbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-left: auto;
        flex-shrink: 0;
    }

    .topbar-user {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 5px 10px;
        border-radius: 8px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .topbar-avatar {
        width: 28px;
        height: 28px;
        background: #1d4ed8;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }

    .topbar-user-name {
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,0.8);
        white-space: nowrap;
    }

    .topbar-user-role {
        font-size: 11px;
        color: rgba(255,255,255,0.3);
        white-space: nowrap;
    }

    .topbar-logout {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 8px;
        background: none;
        border: 1px solid rgba(255,255,255,0.1);
        cursor: pointer;
        color: rgba(255,255,255,0.4);
        font-size: 13px;
        font-weight: 500;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

        .topbar-logout svg {
            width: 15px;
            height: 15px;
        }

        .topbar-logout:hover {
            background: rgba(239,68,68,0.12);
            color: #f87171;
            border-color: rgba(239,68,68,0.25);
        }

    /* Mobile: collapse nav pills into hamburger */
    @@media (max-width: 768px) {
        .topbar-nav {
            display: none;
        }

        .nav-section-chip {
            display: none;
        }

        .nav-divider-v {
            display: none;
        }

        .topbar-brand-text {
            display: none;
        }

        .topbar-user-role {
            display: none;
        }
    }

    /* Animate on load */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .topbar {
        animation: slideDown 0.3s ease both;
    }
</style>

<nav class="topbar">

    <!-- Brand -->
    <a href="" class="topbar-brand">
        <div class="topbar-brand-icon">M</div>
        <span class="topbar-brand-text">Milo's</span>
    </a>

    <!-- Nav pills -->
    <div class="topbar-nav">
        <span class="nav-section-chip">Principal</span>

        <NavLink class="nav-pill" href="" Match="NavLinkMatch.All" ActiveClass="active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
            Inicio
        </NavLink>

        <NavLink class="nav-pill" href="ventas" ActiveClass="active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.99-1.61L23 6H6" />
            </svg>
            Ventas
        </NavLink>

        <NavLink class="nav-pill" href="inventario" ActiveClass="active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
            </svg>
            Inventario
        </NavLink>

        @if (AuthState.EsAdmin)
        {
            <div class="nav-divider-v"></div>
            <span class="nav-section-chip">Admin</span>

            <NavLink class="nav-pill" href="historial" ActiveClass="active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
                Historial
            </NavLink>

            <NavLink class="nav-pill" href="reportes" ActiveClass="active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                </svg>
                Reportes
            </NavLink>

            <NavLink class="nav-pill" href="usuarios" ActiveClass="active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 00-3-3.87" />
                    <path d="M16 3.13a4 4 0 010 7.75" />
                </svg>
                Usuarios
            </NavLink>
        }
    </div>

    <!-- Right: user + logout -->
    <div class="topbar-right">
        <div class="topbar-user">
            <div class="topbar-avatar">
                @(AuthState.Nombre.Length > 0 ? AuthState.Nombre[..1] : "?")
            </div>
            <div>
                <div class="topbar-user-name">@AuthState.Nombre</div>
                <div class="topbar-user-role">@(AuthState.EsAdmin ? "Administrador" : "Vendedor")</div>
            </div>
        </div>

        <button class="topbar-logout" @onclick="CerrarSesion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
            Salir
        </button>
    </div>

</nav>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnChange += async () => await InvokeAsync(StateHasChanged);
    }

    void CerrarSesion()
    {
        AuthState.Logout();
        Nav.NavigateTo("/login", replace: true);
    }
}