<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Milo's SVI</a>
        <button class="navbar-toggler-desktop" @onclick="ToggleSidebar" title="Plegar menú">
            @if (collapsed)
            {
                <span>☰</span>
            }
            else
            {
                <span>✕</span>
            }
        </button>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable @(collapsed ? "collapsed" : "")" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                @if (!collapsed)
                {
                    <span>Inicio</span>
                }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ventas">
                <span class="bi bi-cart-fill-nav-menu" aria-hidden="true"></span>
                @if (!collapsed)
                {
                    <span>Ventas</span>
                }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="inventario">
                <span class="bi bi-box-seam-nav-menu" aria-hidden="true"></span>
                @if (!collapsed)
                {
                    <span>Inventario</span>
                }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="clientes">
                <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span>
                @if (!collapsed)
                {
                    <span>Clientes</span>
                }
            </NavLink>
        </div>
    </nav>
</div>
@code {
    public bool collapsed = false;

    [Parameter] public EventCallback OnToggle { get; set; }

    async Task ToggleSidebar()
    {
        collapsed = !collapsed;
        await OnToggle.InvokeAsync();
    }
}